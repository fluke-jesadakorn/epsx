# EPSX Backend Development Container
# Based on production Rust 1.85-slim with development optimizations

FROM rust:1.85-slim AS base
WORKDIR /workspace

# Install build dependencies (same as production + development tools)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    # Production dependencies
    pkg-config \
    libssl-dev \
    libpq-dev \
    ca-certificates \
    # Development tools
    git \
    curl \
    wget \
    vim \
    nano \
    htop \
    tree \
    jq \
    bash \
    zsh \
    # Database tools for development
    postgresql-client \
    # Build tools for development
    build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Install development Rust tools
RUN rustup component add rustfmt clippy rust-analyzer
# Note: Rust tools will be installed during container startup to save build time
# RUN cargo install diesel_cli@2.2.12 --no-default-features --features postgres
# RUN cargo install cargo-watch cargo-edit cargo-audit  
# RUN cargo install sqlx-cli --no-default-features --features rustls,postgres

# Create development user (same pattern as production)
RUN useradd --create-home --shell /bin/bash --user-group --uid 1001 nonroot

# Install oh-my-zsh for development experience
USER nonroot
RUN sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" || true
USER root

# Set up development environment variables (same as production for compatibility)
ENV RUST_LOG=debug
ENV RUST_BACKTRACE=1
ENV RUST_ENV=development
ENV ENV=development
ENV HOST=0.0.0.0
ENV PORT=8080

# Development optimizations
ENV DATABASE_MAX_CONNECTIONS=5
ENV DATABASE_MIN_CONNECTIONS=1
ENV DATABASE_ACQUIRE_TIMEOUT=30
ENV DATABASE_IDLE_TIMEOUT=300

# Create workspace directory with proper permissions
RUN mkdir -p /workspace && chown -R nonroot:nonroot /workspace

# Set up shell environment for development
RUN echo 'export PATH="$HOME/.cargo/bin:$PATH"' >> /home/nonroot/.bashrc
RUN echo 'export PATH="$HOME/.cargo/bin:$PATH"' >> /home/nonroot/.zshrc || true

# Switch to development user
USER nonroot:nonroot

# Working directory
WORKDIR /workspace

# Expose development port
EXPOSE 8080

# Health check for development
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Development entrypoint with sleep infinity for dev container
CMD ["sleep", "infinity"]