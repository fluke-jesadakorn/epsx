{
  "name": "EPSX Development with Production Docker",
  "dockerComposeFile": "docker-compose.yml",
  "service": "frontend",
  "workspaceFolder": "/workspace",
  
  // Features to add to the dev container
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": true,
      "username": "nextjs",
      "userUid": "1001",
      "userGid": "1001"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "latest"
    }
  },

  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "extensions": [
        // Rust development
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "serayuzgur.crates",
        
        // TypeScript/JavaScript/Next.js
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        
        // Docker and containers
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        
        // Database
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        
        // General utilities
        "ms-vscode.vscode-json",
        "redhat.vscode-yaml",
        "ms-vsliveshare.vsliveshare",
        "GitHub.copilot",
        "ms-vscode.hexdump"
      ],
      
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "rust-analyzer.cargo.buildScripts.enable": true,
        "rust-analyzer.procMacro.enable": true,
        "rust-analyzer.server.path": "/usr/local/cargo/bin/rust-analyzer",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "typescript.preferences.quotemark": "single",
        "javascript.preferences.quotemark": "single",
        "docker.defaultRegistryPath": "gcr.io/epsx-449804"
      }
    }
  },

  // Ports to forward
  "forwardPorts": [
    3000,  // Frontend
    3001,  // Admin Frontend
    8080,  // Backend API
    5432,  // PostgreSQL
    6379,  // Redis
    80,    // HTTP proxy
    443,   // HTTPS proxy
    2019   // Caddy admin
  ],

  "portsAttributes": {
    "3000": {
      "label": "Frontend (epsx.io)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Admin Frontend (admin.epsx.io)",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Backend API (api.epsx.io)",
      "onAutoForward": "notify"
    },
    "443": {
      "label": "HTTPS Proxy",
      "onAutoForward": "notify"
    }
  },

  // Lifecycle scripts
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",

  // Development environment settings
  "remoteUser": "nextjs",
  "containerEnv": {
    "NODE_ENV": "development",
    "RUST_ENV": "development", 
    "ENV": "development",
    "DOMAIN_DEVELOPMENT": "true",
    "PRODUCTION_DOCKER": "true",
    "FRONTEND_CONTAINER": "frontend",
    "BACKEND_CONTAINER": "backend",
    "DATABASE_CONTAINER": "database"
  },

  // Mount the Docker socket for Docker-in-Docker
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind,consistency=cached"
  ]
}