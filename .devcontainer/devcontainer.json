{
  "name": "EPSX Development Environment",
  "dockerComposeFile": "docker-compose.dev.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "nodeGypDependencies": true,
      "version": "18"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "forwardPorts": [80, 443, 3000, 3001, 8080, 8090, 5433, 6381],
  "portsAttributes": {
    "80": {
      "label": "Traefik HTTP (epsx.io, admin.epsx.io, api.epsx.io)",
      "protocol": "http"
    },
    "443": {
      "label": "Traefik HTTPS (epsx.io, admin.epsx.io, api.epsx.io)",
      "protocol": "https"
    },
    "3000": {
      "label": "Frontend (Direct)",
      "protocol": "http"
    },
    "3001": {
      "label": "Admin (Direct)", 
      "protocol": "http"
    },
    "8080": {
      "label": "Backend (Direct)",
      "protocol": "http"
    },
    "8090": {
      "label": "Traefik Dashboard",
      "protocol": "http"
    },
    "5433": {
      "label": "PostgreSQL Database",
      "protocol": "tcp"
    },
    "6381": {
      "label": "Redis Cache",
      "protocol": "tcp"
    }
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode && sudo mkdir -p /home/vscode/.vscode-server && sudo chown -R vscode:vscode /home/vscode/.vscode-server && sudo chown -R vscode:vscode /workspace/node_modules /workspace/.turbo /home/vscode/.local/share/pnpm && ./scripts/devcontainer-setup-domains.sh && pnpm install",
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "updateRemoteUserUID": true
}