# EPSX Frontend Development Container
# Based on production Node.js 22-alpine with development optimizations

FROM node:22-alpine AS base
WORKDIR /workspace

# Install system dependencies (same as production + development tools)
RUN apk add --no-cache \
    libc6-compat \
    dumb-init \
    git \
    openssh \
    curl \
    wget \
    bash \
    zsh \
    vim \
    nano \
    htop \
    tree \
    jq

# Install pnpm (same version as production)
RUN npm install -g pnpm@10.14.0

# Install development tools for Node.js
RUN npm install -g \
    nodemon \
    @types/node \
    typescript \
    tsx \
    prettier \
    eslint

# Create development user (same pattern as production but for dev)
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001
RUN addgroup nextjs wheel

# Install oh-my-zsh for development experience
RUN sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" || true

# Set up development environment
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME="0.0.0.0"

# Create workspace directory with proper permissions
RUN mkdir -p /workspace && chown -R nextjs:nodejs /workspace

# Switch to development user
USER nextjs

# Set up shell environment
RUN echo 'export PATH="/workspace/node_modules/.bin:$PATH"' >> ~/.bashrc
RUN echo 'export PATH="/workspace/node_modules/.bin:$PATH"' >> ~/.zshrc || true

# Working directory
WORKDIR /workspace

# Expose development ports (frontend 3000, admin 3001)
EXPOSE 3000 3001

# Health check for development
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Development entrypoint with sleep infinity for dev container
ENTRYPOINT ["dumb-init", "--"]
CMD ["sleep", "infinity"]