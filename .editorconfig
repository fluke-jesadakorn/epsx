# Editor configuration for EPSX Monorepo
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.rs]
indent_size = 4

[Makefile]
indent_style = tab

[*.py]
indent_size = 4

[*.sh]
indent_size = 2

[*.toml]
indent_size = 2

[*.sql]
indent_size = 2

[docker-compose*.yml]
indent_size = 2

[Dockerfile*]
indent_size = 2
