# ============================================================================
# EPSX Platform - Docker Compose Environment Configuration
# Web3-First Architecture with Cloudflare Tunnel
# ============================================================================
# Copy this file to .env.docker and configure with your values
# ALL VALUES ARE REQUIRED UNLESS MARKED OPTIONAL

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
ENV=development
NODE_ENV=development
RUST_ENV=development
RUST_LOG=info,epsx=debug
LOG_LEVEL=debug

# ============================================================================
# SERVICE URLS - Dev Environment
# ============================================================================
# These URLs will be accessed through Cloudflare Tunnel
BACKEND_URL=https://dev-api.epsx.io
FRONTEND_URL=https://dev.epsx.io
ADMIN_FRONTEND_URL=https://dev-admin.epsx.io

# ============================================================================
# CLOUDFLARE TUNNEL CONFIGURATION
# ============================================================================
# Get tunnel token from: https://dash.cloudflare.com/ → Zero Trust → Access → Tunnels
# Create new tunnel and copy the token
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# ============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# ============================================================================
# PostgreSQL connection settings for Docker deployment
DB_NAME=epsx_dev
DB_USER=epsx_user
DB_PASSWORD=change-this-secure-database-password
DB_PORT=5432

# Database connection pool settings
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=300

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis for caching and session storage
REDIS_PASSWORD=change-this-secure-redis-password
REDIS_PORT=6379

# ============================================================================
# WEB3 AUTHENTICATION - REQUIRED
# ============================================================================
# Modern Web3-first authentication using SIWE (Sign-In with Ethereum)
# No traditional email/password or OIDC authentication - wallet signatures only

# Web3 application secrets (minimum 32 characters for security)
WEB3_APP_SECRET=web3-app-secret-32-chars-minimum-change-in-production
WALLET_SIGNATURE_SECRET=wallet-signature-secret-32-chars-change-production
WEB3_SESSION_SECRET=web3-session-secret-32-chars-change-in-production
JWT_SECRET=jwt-bearer-token-secret-32-chars-change-in-production

# Web3 session management
WEB3_SESSION_DURATION_HOURS=24
WEB3_SIGNATURE_TIMEOUT_MINUTES=10

# ============================================================================
# BLOCKCHAIN CONFIGURATION
# ============================================================================
# Blockchain network selection: testnet or mainnet
BLOCKCHAIN_NETWORK=testnet

# Company wallet addresses for receiving payments
COMPANY_WALLET_MAINNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
COMPANY_WALLET_TESTNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7

# Chain ID for Web3 connections
# BSC Testnet: 97, BSC Mainnet: 56
CHAIN_ID=97

# WalletConnect Configuration
WALLETCONNECT_PROJECT_ID=epsx-web3-dev

# ============================================================================
# BLOCKCHAIN RPC ENDPOINTS
# ============================================================================
# BSC (Binance Smart Chain) RPC URLs
BSC_MAINNET_RPC_URL=https://bsc-dataseed1.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# ============================================================================
# BLOCKCHAIN VERIFICATION SETTINGS
# ============================================================================
# Transaction confirmation requirements
BLOCKCHAIN_CONFIRMATION_TIMEOUT_SECONDS=120
BSC_REQUIRED_CONFIRMATIONS=12
BSC_TESTNET_REQUIRED_CONFIRMATIONS=6
MAX_PAYMENT_AGE_MINUTES=30

# ============================================================================
# FIREBASE ANALYTICS (OPTIONAL) - Frontend Only
# ============================================================================
# Firebase is used ONLY for client-side analytics tracking
# NOT used for authentication (Web3 wallets only)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 1. Copy this file to .env.docker
# 2. Update all secret values (marked with "change-this" or "your-*-here")
# 3. Create Cloudflare Tunnel and paste token above
# 4. Configure DNS CNAME records in Cloudflare:
#    - dev.epsx.io → <tunnel-id>.cfargotunnel.com
#    - dev-admin.epsx.io → <tunnel-id>.cfargotunnel.com
#    - dev-api.epsx.io → <tunnel-id>.cfargotunnel.com
# 5. Run: docker-compose --env-file .env.docker up -d
# 6. Monitor: docker-compose logs -f
