{
  "name": "epsx",
  "private": true,
  "scripts": {
    "prepare": "turbo run build:pkg",
    "dev": "bun run turbo run dev",
    "dev:fe": "turbo run dev:fe",
    "dev:be": "turbo run dev:be",
    "dev:admin": "turbo run dev:admin",
    "build": "turbo run build",
    "build:fe": "turbo run build:fe",
    "build:be": "turbo run build:be",
    "build:admin": "turbo run build:admin",
    "build:pkg": "turbo run build:pkg",
    "build:types": "turbo run build --filter=@epsx/types",
    "build:utils": "turbo run build --filter=@epsx/utils",
    "build:api": "turbo run build --filter=@epsx/api-client",
    "start": "turbo run start",
    "start:fe": "turbo run start:fe",
    "start:be": "turbo run start:be",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "type-check:fe": "turbo run type-check:fe",
    "type-check:pkg": "turbo run type-check --filter=./packages/*",
    "type-check:types": "turbo run type-check --filter=@epsx/types",
    "type-check:utils": "turbo run type-check --filter=@epsx/utils",
    "type-check:api": "turbo run type-check --filter=@epsx/api-client",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.3",
    "@commitlint/config-conventional": "^19.0.3",
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "9.23.0",
    "eslint-config-next": "15.2.3",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "tslib": "^2.6.2",
    "turbo": "2.4.4",
    "typescript": "^5.4.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.4",
  "engines": {
    "bun": ">=1.2.4"
  }
}
