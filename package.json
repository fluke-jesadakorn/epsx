{
  "name": "epsx",
  "private": true,
  "scripts": {
    "prepare": "bun run build:pkg",
    "dev": "bun --cwd apps/frontend dev",
    "dev:fe": "bun --cwd apps/frontend dev",
    "dev:be": "cd apps/backend && cargo run",
    "build": "bun run build:pkg && bun run build:fe",
    "build:fe": "bun --cwd apps/frontend build",
    "build:be": "cd apps/backend && cargo build",
    "build:pkg": "bun run build:types && bun run build:utils && bun run build:api",
    "build:types": "bun --cwd packages/types run build",
    "build:utils": "bun --cwd packages/utils run build",
    "build:api": "bun --cwd packages/api-client run build",
    "start": "bun --cwd apps/frontend start",
    "start:fe": "bun --cwd apps/frontend start",
    "start:be": "cd apps/backend && cargo run",
    "lint": "bun --cwd apps/frontend lint",
    "lint:fix": "bun --cwd apps/frontend lint --fix",
    "type-check": "bun --cwd apps/frontend tsc --noEmit",
    "type-check:fe": "bun --cwd apps/frontend tsc --noEmit",
    "type-check:pkg": "bun run type-check:types && bun run type-check:utils && bun run type-check:api",
    "type-check:types": "bun --cwd packages/types tsc --noEmit",
    "type-check:utils": "bun --cwd packages/utils tsc --noEmit",
    "type-check:api": "bun --cwd packages/api-client tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "rm -rf **/node_modules ./node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "3.3.0",
    "@eslint/js": "^9.8.0",
    "eslint": "9.22.0",
    "eslint-config-next": "15.2.2",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "tslib": "^2.3.0",
    "typescript": "^5.7.3",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.4",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.4"
  },
  "dependencies": {
    "@types/next-auth": "3.13.0",
    "next": "15.2.3",
    "next-auth": "^4.24.11",
    "nookies": "^2.5.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
