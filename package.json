{
  "name": "epsx",
  "private": true,
  "scripts": {
    "prepare": "nx run-many --target=build --projects=types,utils,ui,api-client,shared",
    "dev": "nx run-many --target=serve --parallel --all",
    "dev:fe": "nx run frontend:serve",
    "dev:be": "nx run backend:serve",
    "build": "nx run-many --target=build --all",
    "build:fe": "nx run frontend:build",
    "build:be": "nx run backend:build",
    "build:pkg": "nx run-many --target=build --projects=types,utils,ui,api-client,shared",
    "build:types": "nx run types:build",
    "build:utils": "nx run utils:build",
    "build:ui": "nx run ui:build",
    "build:api": "nx run api-client:build",
    "start": "nx run-many --target=serve --parallel --all",
    "start:fe": "nx run frontend:serve",
    "start:be": "nx run backend:serve",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "type-check": "nx run-many --target=type-check --all",
    "type-check:fe": "nx run frontend:type-check",
    "type-check:pkg": "nx run-many --target=type-check --projects=types,utils,ui,api-client,shared",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "nx reset && rm -rf **/node_modules ./node_modules",
    "clean:pkg": "nx run-many --target=clean --projects=types,utils,ui,api-client,shared"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "3.3.0",
    "@eslint/js": "^9.8.0",
    "@nrwl/next": "^19.8.4",
    "@nrwl/react": "^19.8.4",
    "@nx/devkit": "20.5.0",
    "@nx/eslint": "20.5.0",
    "@nx/eslint-plugin": "20.5.0",
    "@nx/js": "20.5.0",
    "@nx/next": "20.5.0",
    "@nx/playwright": "20.5.0",
    "@nx/plugin": "20.5.0",
    "@nx/workspace": "20.5.0",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.11.8",
    "@swc/helpers": "~0.5.11",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "9.22.0",
    "eslint-config-next": "15.2.2",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "nx": "20.5.0",
    "prettier": "^3.5.2",
    "tslib": "^2.3.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.4",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.4"
  },
  "dependencies": {
    "@types/next-auth": "3.13.0",
    "next": "15.2.1",
    "next-auth": "^4.24.11",
    "nookies": "^2.5.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
