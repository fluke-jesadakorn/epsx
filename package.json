{
  "name": "epsx",
  "private": true,
  "description": "EPSX Monorepo - Data Analytics Platform",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "author": "EPSX Team",
  "packageManager": "bun@1.3.4",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "prepare": "echo 'Standalone mode - no package build required'",
    "postinstall": "echo 'Standalone mode - ready for development'",
    "dev": "bun env:validate && turbo run dev --filter='epsx-frontend' --filter='epsx-admin-frontend' --filter='@epsx/backend' --parallel",
    "dev:anvil": "bun scripts/anvil-proxy.ts",
    "setup:local": "chmod +x apps/contracts/scripts/setup-local.sh && ./apps/contracts/scripts/setup-local.sh",
    "fund:tokens": "chmod +x apps/contracts/scripts/fund-tokens.sh && ./apps/contracts/scripts/fund-tokens.sh",
    "fund:wallet": "chmod +x scripts/dev/fund-wallet.sh && ./scripts/dev/fund-wallet.sh",
    "dev:up": "docker compose -f infrastructure/docker/docker-compose.yml up --build",
    "dev:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "dev:backend:docker": "docker compose -f infrastructure/docker/docker-compose.backend.yml up --build",
    "dev:backend:docker:down": "docker compose -f infrastructure/docker/docker-compose.backend.yml down",
    "dev:logs": "docker compose -f infrastructure/docker/docker-compose.yml logs -f",
    "dev:all": "turbo run dev --filter='epsx-frontend' --filter='epsx-admin-frontend' --filter='@epsx/backend' --parallel",
    "dev:frontend": "turbo run dev --filter='epsx-frontend'",
    "dev:admin": "turbo run dev --filter='epsx-admin-frontend'",
    "dev:backend": "turbo run dev:backend",
    "dev:web": "turbo run dev --filter='epsx-frontend' --filter='epsx-admin-frontend' --parallel",
    "dev:apps": "turbo run dev --filter='./apps/*' --parallel",
    "build": "turbo run build",
    "build:all": "turbo run build",
    "build:dev": "ENV=development NODE_ENV=development turbo run build",
    "build:prod": "ENV=production NODE_ENV=production turbo run build",
    "build:frontend": "turbo run build --filter='epsx-frontend'",
    "build:admin": "turbo run build --filter='epsx-admin-frontend'",
    "build:backend": "turbo run build:backend",
    "build:web": "turbo run build --filter='epsx-frontend' --filter='epsx-admin-frontend' --parallel",
    "build:affected": "turbo run build --affected",
    "start": "turbo run start",
    "start:frontend": "turbo run start:frontend",
    "start:admin": "turbo run start:admin",
    "start:backend": "turbo run start:backend",
    "start:web": "turbo run start:frontend start:admin --parallel",
    "lint": "turbo run lint",
    "lint:frontend": "turbo run lint --filter='epsx-frontend'",
    "lint:admin": "turbo run lint --filter='epsx-admin-frontend'",
    "lint:apps": "turbo run lint --filter='./apps/*' --parallel",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "type-check:apps": "turbo run type-check --filter='./apps/*'",
    "test": "turbo run test",
    "test:backend": "turbo run test:backend",
    "test:frontend": "turbo run test:frontend",
    "test:admin": "turbo run test:admin",
    "test:e2e": "turbo run test:e2e",
    "test:watch": "turbo run test:watch",
    "test:ci": "turbo run test:ci",
    "test:all": "turbo run test:backend test:frontend test:admin test:e2e --parallel",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && bun clean:root",
    "clean:root": "rm -rf node_modules .turbo",
    "clean:cache": "turbo daemon stop && rm -rf .turbo node_modules/.cache",
    "env:setup": "cp .env.example .env && echo '✅ Created .env file. Please edit with your values.'",
    "env:validate": "bun scripts/utils/validate-env.js",
    "docker:prod": "docker-compose -f infrastructure/docker/docker-compose.yml --env-file .env.docker up -d --build",
    "docker:prod:down": "docker-compose -f infrastructure/docker/docker-compose.yml --env-file .env.docker down",
    "docker:prod:logs": "docker-compose -f infrastructure/docker/docker-compose.yml --env-file .env.docker logs -f",
    "docker:rebuild": "docker-compose -f infrastructure/docker/docker-compose.yml down && docker-compose -f infrastructure/docker/docker-compose.yml build --no-cache && docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "deploy:remote": "./scripts/deploy/deploy-remote.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.0.10",
    "@playwright/test": "^1.57.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "baseline-browser-mapping": "^2.9.6",
    "critters": "^0.0.25",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "2.4.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "jsrsasign": "^11.1.0",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "query-string": "^9.3.1",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "turbo": "2.6.3",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.0.67",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@types/pg": "^8.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "global": "^4.4.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "next-themes": "0.4.6",
    "pg": "^8.16.3",
    "pino-pretty": "^13.1.3",
    "react-hook-form": "7.68.0",
    "react-icons": "^5.5.0",
    "siwe": "^3.0.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "thread-stream": "^4.0.0",
    "zod": "3.24.1",
    "zustand": "^5.0.9"
  },
  "main": "oauth-test-server.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluke-jesadakorn/epsx.git"
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/fluke-jesadakorn/epsx/issues"
  },
  "homepage": "https://github.com/fluke-jesadakorn/epsx#readme"
}
