{
  "name": "epsx",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:services": "turbo run build --filter=./apps/{backend,standalone}",
    "build:frontend": "turbo run build --filter=@epsx/frontend",
    "dev": "turbo dev",
    "dev:frontend": "turbo run dev --filter=@epsx/frontend",
    "dev:services": "turbo run dev --filter=./apps/{backend,standalone} --parallel",
    "start:services": "turbo run start --filter=./apps/{backend,gateway} --parallel",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.2",
    "cookies-next": "^5.1.0",
    "firebase": "^11.3.1",
    "firebase-admin": "^13.1.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "stripe": "^17.7.0",
    "swr": "^2.3.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@shadcn/ui": "^0.0.4",
    "@tanstack/react-table": "^8.21.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.476.0",
    "next-themes": "^0.4.4",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@turbo/gen": "^1.13.4",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "9.1.0",
    "prettier": "^3.5.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.4"
}
