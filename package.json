{
  "name": "epsx",
  "private": true,
  "description": "EPSX Monorepo - Trading Platform",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "author": "EPSX Team",
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "prepare": "turbo run build:packages",
    "postinstall": "turbo run build:packages",
    "// Development Scripts": "===================================",
    "dev": "pnpm build:types-first && turbo run dev --parallel",
    "dev:unsafe": "turbo run dev --parallel",
    "dev:all": "pnpm build:types-first && turbo run dev:frontend dev:admin dev:backend --parallel",
    "dev:frontend": "pnpm build:types-first && turbo run dev:frontend",
    "dev:admin": "pnpm build:types-first && turbo run dev:admin",
    "dev:backend": "turbo run dev:backend",
    "dev:packages": "pnpm build:types-first && turbo run dev:packages --parallel",
    "dev:web": "pnpm build:types-first && turbo run dev:frontend dev:admin --parallel",
    "dev:apps": "pnpm build:types-first && turbo run dev --filter='./apps/*' --parallel",
    "dev:pkgs": "pnpm build:types-first && turbo run dev --filter='./packages/*' --parallel",
    "// Build Scripts": "===================================",
    "build": "turbo run build",
    "build:all": "turbo run build:packages build:apps build:backend --parallel",
    "build:apps": "turbo run build:apps",
    "build:packages": "turbo run build:packages",
    "build:types-first": "turbo run build:types --filter='@epsx/types' && turbo run build:packages",
    "build:frontend": "turbo run build:frontend",
    "build:admin": "turbo run build:admin",
    "build:backend": "turbo run build:backend",
    "build:web": "turbo run build:frontend build:admin --parallel",
    "// Start Scripts": "===================================",
    "start": "turbo run start",
    "start:all": "turbo run start:frontend start:admin start:backend --parallel",
    "start:frontend": "turbo run start:frontend",
    "start:admin": "turbo run start:admin",
    "start:backend": "turbo run start:backend",
    "start:web": "turbo run start:frontend start:admin --parallel",
    "// Quality Assurance": "===================================",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "type-check:packages": "turbo run type-check --filter='./packages/*'",
    "type-check:apps": "turbo run type-check --filter='./apps/*'",
    "// Testing Scripts": "===================================",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "test:watch": "turbo run test -- --watch",
    "// Code Formatting": "===================================",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "// Cleanup Scripts": "===================================",
    "clean": "turbo run clean && pnpm clean:root",
    "clean:root": "rm -rf node_modules .turbo",
    "clean:cache": "turbo daemon stop && rm -rf .turbo node_modules/.cache",
    "// Environment Setup": "===================================",
    "env:setup": "chmod +x scripts/setup-environment.sh",
    "env:dev": "./scripts/setup-environment.sh dev",
    "env:test": "./scripts/setup-environment.sh test",
    "env:prod": "./scripts/setup-environment.sh prod",
    "// Docker Commands": "===================================",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:test": "docker-compose -f docker-compose.test.yml up -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:test:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:rebuild": "docker-compose down && docker-compose build --no-cache && docker-compose up -d",
    "// Release Scripts": "===================================",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "// Admin Scripts": "===================================",
    "promote-admin": "node scripts/promote-user-admin.js promote",
    "assign-iam": "node scripts/assign-iam-acl.js assign",
    "list-profiles": "node scripts/assign-iam-acl.js list",
    "// Workspace Management": "===================================",
    "workspace:graph": "turbo run build --graph",
    "workspace:lint": "pnpm lint --recursive",
    "workspace:outdated": "pnpm outdated --recursive"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.1",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "9.23.0",
    "eslint-config-next": "15.2.3",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "^9.1.7",
    "jsrsasign": "^11.1.0",
    "prettier": "^3.6.2",
    "query-string": "^9.2.2",
    "tslib": "^2.8.1",
    "turbo": "2.5.5",
    "typescript": "^5.8.3",
    "uuid": "^11.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react-icons": "^5.5.0"
  }
}
