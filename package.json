{
  "name": "epsx",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=./packages/* && turbo run build --filter=./apps/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:services": "turbo run build --filter=./apps/{backend,standalone}",
    "build:frontend": "turbo run build --filter=@epsx/frontend...",
    "dev": "turbo dev",
    "dev:frontend": "turbo run dev --filter=@epsx/frontend",
    "dev:services": "turbo run dev --filter=./apps/{backend,standalone} --parallel",
    "start:frontend": "turbo run start --filter=@epsx/frontend",
    "start:services": "turbo run start --filter=./apps/{backend,gateway} --parallel",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@turbo/gen": "^1.13.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.4"
}
