{
  "name": "epsx",
  "private": true,
  "scripts": {
    "prepare": "turbo run build:pkg",
    "dev": "turbo run dev",
    "dev:fe": "turbo run dev:fe",
    "dev:admin": "turbo run dev:admin",
    "build": "turbo run build",
    "build:fe": "turbo run build:fe",
    "build:admin": "turbo run build:admin",
    "build:pkg": "turbo run build:pkg",
    "build:types": "turbo run build --filter=@epsx/types",
    "build:utils": "turbo run build --filter=@epsx/utils",
    "build:api": "turbo run build --filter=@epsx/api-client",
    "build:auth": "turbo run build --filter=@epsx/auth",
    "start": "turbo run start",
    "start:fe": "turbo run start:fe",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "type-check:fe": "turbo run type-check:fe",
    "type-check:pkg": "turbo run type-check --filter=./packages/*",
    "type-check:types": "turbo run type-check --filter=@epsx/types",
    "type-check:utils": "turbo run type-check --filter=@epsx/utils",
    "type-check:api": "turbo run type-check --filter=@epsx/api-client",
    "type-check:auth": "turbo run type-check --filter=@epsx/auth",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "env:setup": "chmod +x scripts/setup-environment.sh",
    "env:dev": "./scripts/setup-environment.sh dev",
    "env:test": "./scripts/setup-environment.sh test",
    "env:prod": "./scripts/setup-environment.sh prod",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:test": "docker-compose -f docker-compose.test.yml up -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:test:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.1",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "9.23.0",
    "eslint-config-next": "15.2.3",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "^9.1.7",
    "jsrsasign": "^11.1.0",
    "prettier": "^3.6.2",
    "query-string": "^9.2.2",
    "tslib": "^2.8.1",
    "turbo": "2.5.4",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "apps/frontend",
    "apps/admin-frontend",
    "packages/*"
  ],
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "react-icons": "^5.5.0"
  }
}
