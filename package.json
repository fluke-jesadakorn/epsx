{
  "name": "epsx",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:services": "turbo run build --filter=./apps/{backend,standalone}",
    "build:frontend": "turbo run build --filter=@epsx/frontend",
    "dev": "turbo run dev --parallel",
    "dev:frontend": "turbo run dev --filter=@epsx/frontend",
    "dev:services": "turbo run dev --filter=./apps/{backend,standalone} --parallel",
    "start": "turbo run start --parallel",
    "start:frontend": "turbo run start --filter=@epsx/frontend",
    "start:services": "turbo run start --filter=./apps/{backend,standalone} --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "type-check:packages": "turbo run type-check --filter=./packages/*",
    "type-check:services": "turbo run type-check --filter=./apps/{backend,standalone}",
    "type-check:frontend": "turbo run type-check --filter=@epsx/frontend",
    "clean": "rm -rf **/node_modules ./node_modules",
    "clean:packages": "turbo run clean --filter=./packages/*",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "postinstall": "turbo run build --filter=@epsx/shared"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@turbo/gen": "^1.13.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.4",
  "engines": {
    "node": ">=22.14.0",
    "bun": ">=1.2.4"
  }
}
