{
  "name": "epsx",
  "private": true,
  "description": "EPSX Monorepo - Trading Platform",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "author": "EPSX Team",
  "packageManager": "bun@1.1.42",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "prepare": "echo 'Standalone mode - no package build required'",
    "postinstall": "echo 'Standalone mode - ready for development'",
    "dev": "bun env:validate && turbo run dev --filter='epsx-frontend' --filter='epsx-admin-frontend' --filter='@epsx/backend' --parallel",
    "dev:domains": "./scripts/utils/dev-with-domains.sh",
    "dev:domains:setup": "./scripts/utils/setup-domains.sh",
    "dev:domains:cleanup": "./scripts/utils/cleanup-domains.sh",
    "dev:domains:validate": "./scripts/utils/validate-domains.sh",
    "dev:domains:stop": "./scripts/utils/stop-dev.sh",
    "dev:setup": "./scripts/utils/setup-domains.sh && docker compose up --build",
    "dev:up": "docker compose up --build",
    "dev:down": "docker compose down",
    "dev:clean": "./scripts/utils/cleanup-domains.sh",
    "dev:logs": "docker compose logs -f",
    "dev:container": "./scripts/utils/validate-domains.sh && docker compose up --build",
    "dev:localhost": "docker compose up --build",
    "dev:container:down": "docker compose down",
    "dev:all": "turbo run dev --filter='epsx-frontend' --filter='epsx-admin-frontend' --filter='@epsx/backend' --parallel",
    "dev:frontend": "turbo run dev --filter='epsx-frontend'",
    "dev:admin": "turbo run dev --filter='epsx-admin-frontend'",
    "dev:backend": "turbo run dev:backend",
    "dev:web": "turbo run dev --filter='epsx-frontend' --filter='epsx-admin-frontend' --parallel",
    "dev:apps": "turbo run dev --filter='./apps/*' --parallel",
    "build": "./scripts/build-all.sh",
    "build:all": "./scripts/build-all.sh",
    "build:dev": "./scripts/build-dev.sh",
    "build:staging": "./scripts/build-staging.sh",
    "build:prod": "./scripts/build-prod.sh",
    "build:cloud-run": "./scripts/build-turborepo.sh",
    "build:apps": "turbo run build:apps",
    "build:frontend": "turbo run build:frontend",
    "build:admin": "turbo run build:admin",
    "build:backend": "turbo run build:backend",
    "build:web": "turbo run build:frontend build:admin --parallel",
    "start": "turbo run start",
    "start:all": "turbo run start:frontend start:admin start:backend --parallel",
    "start:frontend": "turbo run start:frontend",
    "start:admin": "turbo run start:admin",
    "start:backend": "turbo run start:backend",
    "start:web": "turbo run start:frontend start:admin --parallel",
    "lint": "turbo run lint",
    "lint:frontend": "turbo run lint --filter='epsx-frontend'",
    "lint:admin": "turbo run lint --filter='epsx-admin-frontend'",
    "lint:apps": "turbo run lint --filter='./apps/*' --parallel",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "type-check:apps": "turbo run type-check --filter='./apps/*'",
    "test": "turbo run test",
    "test:domain": "turbo run test:domain",
    "test:application": "turbo run test:application",
    "test:infrastructure": "turbo run test:infrastructure",
    "test:presentation": "turbo run test:presentation",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:backend": "turbo run test:backend",
    "test:frontend": "turbo run test:frontend",
    "test:admin": "turbo run test:admin",
    "test:e2e:frontend": "turbo run test:e2e:frontend",
    "test:e2e:admin": "turbo run test:e2e:admin",
    "test:watch": "turbo run test:watch",
    "test:ci": "turbo run test:ci",
    "test:parallel": "turbo run test:parallel",
    "test:all": "turbo run test:backend test:frontend test:admin test:e2e --parallel",
    "test:layers": "turbo run test:domain test:application test:infrastructure test:presentation --parallel",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && bun clean:root",
    "clean:root": "rm -rf node_modules .turbo",
    "clean:cache": "turbo daemon stop && rm -rf .turbo node_modules/.cache",
    "env:setup": "cp .env.example .env && echo '✅ Created .env file. Please edit with your values.'",
    "env:setup:old": "chmod +x scripts/*.sh .devtools/*.sh",
    "env:dev": "./scripts/env-manager.sh development",
    "env:staging": "./scripts/env-manager.sh staging",
    "env:prod": "./scripts/env-manager.sh production",
    "env:cloud-run": "./scripts/env-manager.sh cloud-run",
    "env:status": "./scripts/env-manager.sh status",
    "env:validate": "node scripts/utils/validate-env.js",
    "env:validate:old": "./scripts/env-manager.sh validate",
    "env:list": "./scripts/env-manager.sh list",
    "setup:dev": "./scripts/setup-environment.sh dev",
    "setup:test": "./scripts/setup-environment.sh test",
    "setup:staging": "./scripts/setup-environment.sh staging",
    "setup:prod": "./scripts/setup-environment.sh prod",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:test": "docker-compose -f docker-compose.test.yml up -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:test:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:rebuild": "docker-compose down && docker-compose build --no-cache && docker-compose up -d",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "promote-admin": "node scripts/promote-user-admin.js promote",
    "assign-iam": "node scripts/assign-iam-acl.js assign",
    "list-profiles": "node scripts/assign-iam-acl.js list",
    "workspace:graph": "turbo run build --graph",
    "workspace:lint": "bun lint --recursive",
    "workspace:outdated": "bun outdated --recursive",
    "debug:env": "./.devtools/debug-env.sh",
    "debug:env:all": "./.devtools/debug-env.sh --all",
    "debug:env:missing": "./.devtools/debug-env.sh --missing",
    "debug:env:files": "./.devtools/debug-env.sh --files",
    "debug:env:export": "./.devtools/debug-env.sh --export",
    "deploy:dev": "bun env:validate && ./scripts/deploy/development.sh",
    "deploy:staging": "bun env:validate && ./scripts/deploy/staging.sh",
    "deploy:prod": "bun env:validate && ./scripts/deploy/production.sh",
    "deploy:staging:old": "./scripts/deploy-staging.sh",
    "deploy:prod:old": "./scripts/deploy-cloudrun.sh",
    "build:affected": "turbo run build --affected",
    "docker:build:affected": "./scripts/docker-build-affected.sh",
    "deploy:backend": "./scripts/deploy/service.sh backend",
    "deploy:frontend": "./scripts/deploy/service.sh frontend",
    "deploy:admin": "./scripts/deploy/service.sh admin",
    "deploy:all:dev": "ENV=development bun deploy:dev",
    "deploy:all:staging": "ENV=staging bun deploy:staging",
    "deploy:all:prod": "ENV=production bun deploy:prod"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.56.1",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "critters": "^0.0.25",
    "eslint": "9.23.0",
    "eslint-config-next": "15.2.3",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "^9.1.7",
    "jsrsasign": "^11.1.0",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "query-string": "^9.3.1",
    "tslib": "^2.8.1",
    "turbo": "2.5.6",
    "typescript": "^5.9.3",
    "uuid": "^11.1.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "jose": "^5.10.0",
    "lucide-react": "^0.544.0",
    "next": "15.5.2",
    "react-hook-form": "7.58.1",
    "react-icons": "^5.5.0",
    "siwe": "^2.3.2",
    "zod": "4.0.15",
    "zustand": "^5.0.8"
  },
  "main": "oauth-test-server.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluke-jesadakorn/epsx.git"
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/fluke-jesadakorn/epsx/issues"
  },
  "homepage": "https://github.com/fluke-jesadakorn/epsx#readme"
}
