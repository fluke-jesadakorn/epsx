{
  "version": 2,
  "projects": {
    "api-client": {
      "root": "packages/api-client",
      "sourceRoot": "packages/api-client/src",
      "projectType": "library",
      "dependencies": ["types", "shared"],
      "targets": {
        "lint": {
          "executor": "@nx/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["packages/api-client/**/*.ts"]
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "outputs": ["packages/api-client/dist"],
          "options": {
            "command": "tsc --project tsconfig.json",
            "cwd": "packages/api-client"
          }
        }
      },
      "tags": ["scope:api"]
    },
    "types": {
      "root": "packages/types",
      "sourceRoot": "packages/types/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nx/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["packages/types/**/*.ts"]
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "outputs": ["packages/types/dist"],
          "options": {
            "command": "tsc --project tsconfig.json",
            "cwd": "packages/types"
          }
        }
      },
      "tags": ["scope:types"]
    },
    "utils": {
      "root": "packages/utils",
      "sourceRoot": "packages/utils/src",
      "projectType": "library",
      "dependencies": ["types"],
      "targets": {
        "lint": {
          "executor": "@nx/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["packages/utils/**/*.ts"]
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "outputs": ["packages/utils/dist"],
          "options": {
            "command": "tsc --project tsconfig.json",
            "cwd": "packages/utils"
          }
        }
      },
      "tags": ["scope:utils"]
    },
    "shared": {
      "root": "packages/shared",
      "sourceRoot": "packages/shared/src",
      "projectType": "library",
      "dependencies": ["types", "utils"],
      "targets": {
        "lint": {
          "executor": "@nx/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["packages/shared/**/*.ts"]
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "outputs": ["packages/shared/dist"],
          "options": {
            "command": "tsc --project tsconfig.json",
            "cwd": "packages/shared"
          }
        }
      },
      "tags": ["scope:shared"]
    },
    "ui": {
      "root": "packages/ui",
      "sourceRoot": "packages/ui/src",
      "projectType": "library",
      "dependencies": ["types", "utils"],
      "targets": {
        "lint": {
          "executor": "@nx/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["packages/ui/**/*.{ts,tsx}"]
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "outputs": ["packages/ui/dist"],
          "options": {
            "command": "tsc --project tsconfig.json",
            "cwd": "packages/ui"
          }
        }
      },
      "tags": ["scope:ui"]
    },
    "frontend": {
      "root": "apps/frontend",
      "sourceRoot": "apps/frontend",
      "projectType": "application",
      "dependencies": ["shared", "utils", "types", "ui", "api-client"],
      "targets": {
        "lint": {
          "executor": "@nx/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["apps/frontend/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "outputs": ["apps/frontend/.next", "apps/frontend/dist"],
          "options": {
            "command": "next build",
            "cwd": "apps/frontend"
          }
        },
        "serve": {
          "executor": "nx:run-commands",
          "options": {
            "command": "next dev",
            "cwd": "apps/frontend"
          }
        }
      },
      "tags": []
    },
    "backend": {
      "root": "apps/backend",
      "sourceRoot": "apps/backend/src",
      "projectType": "application",
      "dependencies": ["shared"],
      "targets": {
        "lint": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cargo clippy",
            "cwd": "apps/backend"
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cargo build --release",
            "cwd": "apps/backend"
          }
        },
        "serve": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cargo watch -x run",
            "cwd": "apps/backend"
          }
        }
      },
      "tags": []
    }
  }
}
