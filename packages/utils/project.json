{
  "name": "utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/utils/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/utils"],
      "options": {
        "command": "tsup",
        "cwd": "packages/utils"
      },
      "dependsOn": [
        {
          "target": "build",
          "projects": ["types"]
        }
      ]
    }
  }
}
