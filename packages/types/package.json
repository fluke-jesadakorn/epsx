{
  "name": "@epsx/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for EPSX platform",
  "keywords": [
    "types",
    "typescript",
    "epsx"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schemas/payment": {
      "types": "./dist/schemas/payment.d.ts",
      "import": "./dist/schemas/payment.mjs",
      "require": "./dist/schemas/payment.js"
    },
    "./schemas/user": {
      "types": "./dist/schemas/user.d.ts",
      "import": "./dist/schemas/user.mjs",
      "require": "./dist/schemas/user.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:packages": "tsup",
    "dev": "tsup --watch",
    "dev:packages": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache .turbo"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "@epsx/shared-core": "workspace:*"
  },
  "devDependencies": {
    "@epsx/config": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "@types/node": "22.13.11"
  },
  "peerDependencies": {
    "zod": "^3.22.4"
  }
}
