{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "tsBuildInfoFile": null,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@epsx/types": ["../types/src/index.ts", "../types/dist/index.d.ts", "../types/dist/index.js"],
      "@epsx/types/*": ["../types/src/*", "../types/dist/*"],
      "@epsx/shared-core": ["../shared-core/src/index.ts", "../shared-core/dist/index.d.ts", "../shared-core/dist/index.js"],
      "@epsx/shared-core/*": ["../shared-core/src/*", "../shared-core/dist/*"],
      "@epsx/shared-utils": ["../shared-utils/src/index.ts", "../shared-utils/dist/index.d.ts", "../shared-utils/dist/index.js"],
      "@epsx/shared-utils/*": ["../shared-utils/src/*", "../shared-utils/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.*", "**/*.spec.*"]
}