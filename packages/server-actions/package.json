{
  "name": "@epsx/server-actions",
  "version": "0.1.0",
  "description": "Shared server actions for EPSX applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@epsx/shared-core": "workspace:*",
    "@epsx/types": "workspace:*",
    "next": "15.4.4",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
