{
  "name": "@epsx/auth",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.mjs",
      "require": "./dist/session.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.mjs",
      "require": "./dist/context.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.mjs",
      "require": "./dist/actions.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "import": "./dist/service.mjs",
      "require": "./dist/service.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "clean": "rm -rf dist node_modules/.cache",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@epsx/types": "workspace:*",
    "@epsx/utils": "workspace:*",
    "firebase-admin": "13.2.0"
  },
  "peerDependencies": {
    "firebase": "^11.9.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.11",
    "@types/react": "^19.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2"
  }
}
