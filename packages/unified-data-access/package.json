{
  "name": "@epsx/unified-data-access",
  "version": "0.1.0",
  "private": true,
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs", 
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "eslint src",
    "build": "tsup",
    "build:packages": "tsup",
    "dev": "tsup --watch",
    "dev:packages": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@epsx/types": "workspace:*",
    "@epsx/shared-core": "workspace:*",
    "@epsx/shared-utils": "workspace:*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2"
  }
}