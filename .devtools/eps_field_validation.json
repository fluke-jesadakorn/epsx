  "validation_tests": [
    {
      "test_name": "NVDA_EPS_TTM_vs_FQ_Comparison",
      "symbol": "NVDA",
      "reference_data": {
        "expected_quarterly_eps_q4_2024": 0.81,
        "expected_quarterly_eps_q1_2025": 0.89,
        "source": "TradingView UI screenshot + NVDA_comprehensive_eps_analysis.json"
      },
      "backend_extraction_test": {
        "ttm_fields": {
          "earnings_per_share_diluted_ttm": {
            "field_index": 19,
            "expected_value_range": [50.0, 60.0],
            "description": "Trailing twelve months EPS - should be ~56.50"
          },
          "earnings_per_share_basic_ttm": {
            "field_index": 18,
            "expected_value_range": [50.0, 60.0],
            "description": "Basic TTM EPS - should be ~50.85"
          }
        },
        "fq_fields": {
          "earnings_per_share_fq": {
            "field_index": 14,
            "expected_value_range": [0.5, 1.0],
            "description": "Fiscal quarter EPS - should be ~0.81"
          },
          "earnings_per_share_forecast_fq": {
            "field_index": 22,
            "expected_value_range": [0.8, 1.0],
            "description": "Forecast quarterly EPS"
          },
          "earnings_per_share_forecast_next_fq": {
            "field_index": 23,
            "expected_value_range": [0.8, 1.0],
            "description": "Next quarter forecast EPS"
          }
        }
      },
      "validation_criteria": {
        "issue_identification": "TTM values (50-60 range) being used instead of FQ values (0.5-1.0 range)",
        "correct_field_usage": "earnings_per_share_fq (index 14) should be used for quarterly EPS",
        "incorrect_field_usage": "earnings_per_share_diluted_ttm (index 19) should NOT be used for quarterly display"
      }
    },
    {
      "test_name": "QoQ_Growth_Field_Validation",
      "symbol": "NVDA",
      "issue_description": "QoQ growth using TTM YoY growth instead of quarterly growth",
      "current_backend_logic": {
        "field_used": "earnings_per_share_diluted_yoy_growth_ttm",
        "field_index": 20,
        "problem": "YoY TTM growth is not quarter-over-quarter growth"
      },
      "correct_logic": {
        "field_to_use": "earnings_per_share_diluted_qoq_growth_fq",
        "calculation_method": "Use quarterly EPS progression from WebSocket st4_earnings_study data",
        "data_source": "quarterly_eps_data array from NVDA_comprehensive_eps_analysis.json"
      },
      "expected_qoq_calculation": {
        "q1_2025_eps": 0.89,
        "q4_2024_eps": 0.81,
        "qoq_growth_percent": 9.88,
        "formula": "((0.89 - 0.81) / 0.81) * 100"
      }
    },
    {
      "test_name": "Column_Index_Mapping_Verification",
      "description": "Verify TradingView API response column indices match expected fields",
      "expected_column_mapping": {
        "index_14": "earnings_per_share_fq",
        "index_18": "price_earnings_ttm", 
        "index_19": "earnings_per_share_diluted_ttm",
        "index_20": "earnings_per_share_diluted_yoy_growth_ttm",
        "index_22": "earnings_per_share_forecast_fq",
        "index_23": "earnings_per_share_forecast_next_fq"
      },
      "validation_method": "Check backend logs for COLUMN MAPPING VERIFICATION output",
      "potential_issue": "Column index shifting causing wrong field extraction"
    }
  ],
