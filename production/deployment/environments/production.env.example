# EPSX Production Environment Configuration
# Copy this file to .env.production and update with your production values
# Keep this secure and never commit to version control

ENV=production
NODE_ENV=production
RUST_ENV=production

# Production URLs (Current - DO NOT CHANGE)
BACKEND_URL=https://api.epsx.io
FRONTEND_URL=https://epsx.io
ADMIN_FRONTEND_URL=https://admin.epsx.io

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=https://api.epsx.io
NEXT_PUBLIC_APP_URL=https://epsx.io
NEXT_PUBLIC_ADMIN_URL=https://admin.epsx.io

# Core Infrastructure (Required - 4 variables)
DATABASE_URL=postgresql://neondb_owner:PRODUCTION_PASSWORD@your-production-db-host/neondb?sslmode=require&channel_binding=require
NEXTAUTH_SECRET=prod-epsx-jwt-secret-2024-ultra-secure-32-chars-minimum

# OIDC Configuration (Required - 4 variables)
OIDC_CLIENT_ID=epsx-frontend-prod
OIDC_CLIENT_SECRET=production-oidc-client-secret-replace-this
OIDC_ADMIN_CLIENT_ID=epsx-admin-prod
OIDC_ADMIN_CLIENT_SECRET=production-oidc-admin-secret-replace-this

# Firebase Configuration (Required - 3 variables)
FIREBASE_PROJECT_ID=epsx-449804
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRODUCTION_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-production-service-account@epsx-449804.iam.gserviceaccount.com

# Client-accessible Firebase (Optional - 7 variables)
NEXT_PUBLIC_FIREBASE_API_KEY=your-production-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=epsx-449804.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=epsx-449804
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=epsx-449804.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-production-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-production-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-production-analytics-measurement-id

# OAuth Client ID (exposed to browser)
NEXT_PUBLIC_OAUTH_CLIENT_ID=epsx-frontend-prod

# Optional Services (2 variables)
MUSEPAY_PARTNER_ID=your-production-musepay-partner-id
MUSEPAY_PRIVATE_KEY=your-production-musepay-private-key

# Infrastructure (Optional)
REDIS_URL=redis://your-production-redis-host:6379
LOG_LEVEL=info

# Production-specific optimizations (automatically set by deploy script)
DATABASE_ACQUIRE_TIMEOUT=90
DATABASE_MAX_CONNECTIONS=2
DATABASE_MIN_CONNECTIONS=1
SKIP_DB_TEST=true