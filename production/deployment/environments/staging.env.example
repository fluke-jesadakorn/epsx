# EPSX Staging Environment Configuration  
# Copy this file to .env.staging and update with your staging values

ENV=staging
NODE_ENV=staging
RUST_ENV=staging

# Staging URLs
BACKEND_URL=https://staging-api.epsx.io
FRONTEND_URL=https://staging.epsx.io
ADMIN_FRONTEND_URL=https://staging-admin.epsx.io

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=https://staging-api.epsx.io
NEXT_PUBLIC_APP_URL=https://staging.epsx.io
NEXT_PUBLIC_ADMIN_URL=https://staging-admin.epsx.io

# Core Infrastructure (Required - 4 variables)
DATABASE_URL=postgresql://staging_user:staging_password@your-staging-db-host/epsx_staging?sslmode=require
NEXTAUTH_SECRET=staging-secret-32-chars-minimum-replace-this

# OIDC Configuration (Required - 4 variables)
OIDC_CLIENT_ID=epsx-frontend-staging
OIDC_CLIENT_SECRET=staging-oidc-client-secret-replace-this
OIDC_ADMIN_CLIENT_ID=epsx-admin-staging
OIDC_ADMIN_CLIENT_SECRET=staging-oidc-admin-secret-replace-this

# Firebase Configuration (Required - 3 variables)
FIREBASE_PROJECT_ID=your-staging-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_STAGING_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-staging-service-account@your-project.iam.gserviceaccount.com

# Client-accessible Firebase (Optional - 7 variables)
NEXT_PUBLIC_FIREBASE_API_KEY=your-staging-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-staging-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-staging-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-staging-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-staging-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-staging-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-staging-analytics-measurement-id

# OAuth Client ID (exposed to browser)
NEXT_PUBLIC_OAUTH_CLIENT_ID=epsx-frontend-staging


# Infrastructure (Optional)
REDIS_URL=redis://your-staging-redis-host:6379
LOG_LEVEL=info