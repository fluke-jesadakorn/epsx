# EPSX Staging Environment Configuration - Web3 Wallet-First System
# Copy this file to .env.staging and update with your staging values

ENV=staging
NODE_ENV=staging
RUST_ENV=staging

# Staging URLs
BACKEND_URL=https://staging-api.epsx.io
FRONTEND_URL=https://staging.epsx.io
ADMIN_FRONTEND_URL=https://staging-admin.epsx.io

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=https://staging-api.epsx.io
NEXT_PUBLIC_APP_URL=https://staging.epsx.io
NEXT_PUBLIC_ADMIN_URL=https://staging-admin.epsx.io

# Core Infrastructure (Required - 1 variable)
DATABASE_URL=postgresql://staging_user:staging_password@your-staging-db-host/epsx_staging?sslmode=require

# Web3 Authentication Configuration (Required)
# Modern Web3-first authentication using SIWE (Sign-In with Ethereum)
# No traditional email/password, OIDC, or Firebase authentication - wallet signatures only
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=epsx-web3-frontend

# Web3 Session Management (Required)
# Session tokens for authenticated wallet users
WEB3_SESSION_SECRET=staging-web3-session-secret-32-chars-minimum-replace-this
WEB3_SESSION_DURATION_HOURS=24
WEB3_SIGNATURE_TIMEOUT_MINUTES=10


# Infrastructure (Optional)
REDIS_URL=redis://your-staging-redis-host:6379
LOG_LEVEL=info