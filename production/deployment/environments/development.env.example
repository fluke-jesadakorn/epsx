# EPSX Web3-First Development Environment Configuration
# Copy this file to .env.development and update with your development values

ENV=development
NODE_ENV=development
RUST_ENV=development

# Development URLs
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Core Infrastructure (Required - 4 variables)
DATABASE_URL=postgresql://postgres:password@localhost:5432/epsx_db

# Web3 Authentication (Required - 2 variables)
WEB3_APP_SECRET=web3-default-secret-for-development-only-change-in-production
WALLET_SIGNATURE_SECRET=wallet-signature-secret-development-change-in-production

# Web3 Configuration (Client-accessible)
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=epsx-web3-dev
NEXT_PUBLIC_CHAIN_ID=97

# Client-accessible Firebase Analytics (Optional - 4 variables)
NEXT_PUBLIC_FIREBASE_API_KEY=your-dev-firebase-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-dev-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-dev-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-dev-analytics-measurement-id


# Infrastructure (Optional)
REDIS_URL=redis://localhost:6379
LOG_LEVEL=debug