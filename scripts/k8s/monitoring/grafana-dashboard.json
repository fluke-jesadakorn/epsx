{
  "dashboard": {
    "id": null,
    "title": "EPSX Application Dashboard",
    "tags": ["epsx", "application"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"backend-service\"}[5m])",
            "legendFormat": "{{method}} {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "lines": true,
        "linewidth": 2,
        "points": false,
        "pointradius": 2,
        "bars": false,
        "stack": false,
        "percentage": false,
        "legend": {
          "show": true,
          "values": false,
          "min": false,
          "max": false,
          "current": false,
          "avg": false,
          "alignAsTable": false
        },
        "fill": 1,
        "fillGradient": 0,
        "nullPointMode": "null",
        "steppedLine": false,
        "tooltip": {
          "value_type": "cumulative",
          "shared": true
        }
      },
      {
        "id": 2,
        "title": "Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"backend-service\"}[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"backend-service\"}[5m]))",
            "legendFormat": "50th percentile"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "lines": true,
        "linewidth": 2,
        "points": false,
        "pointradius": 2,
        "bars": false,
        "stack": false,
        "percentage": false,
        "legend": {
          "show": true,
          "values": false,
          "min": false,
          "max": false,
          "current": false,
          "avg": false,
          "alignAsTable": false
        },
        "fill": 1,
        "fillGradient": 0,
        "nullPointMode": "null",
        "steppedLine": false,
        "tooltip": {
          "value_type": "cumulative",
          "shared": true
        },
        "yAxes": [
          {
            "label": "Seconds",
            "show": true,
            "logBase": 1,
            "min": 0,
            "max": null,
            "format": "short"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"backend-service\",status=~\"5..\"}[5m])",
            "legendFormat": "5xx errors"
          },
          {
            "expr": "rate(http_requests_total{job=\"backend-service\",status=~\"4..\"}[5m])",
            "legendFormat": "4xx errors"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "lines": true,
        "linewidth": 2,
        "points": false,
        "pointradius": 2,
        "bars": false,
        "stack": false,
        "percentage": false,
        "legend": {
          "show": true,
          "values": false,
          "min": false,
          "max": false,
          "current": false,
          "avg": false,
          "alignAsTable": false
        },
        "fill": 1,
        "fillGradient": 0,
        "nullPointMode": "null",
        "steppedLine": false,
        "tooltip": {
          "value_type": "cumulative",
          "shared": true
        }
      },
      {
        "id": 4,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{pod=~\"backend-.*|frontend-.*|admin-frontend-.*\"}[5m])",
            "legendFormat": "{{pod}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "lines": true,
        "linewidth": 2,
        "points": false,
        "pointradius": 2,
        "bars": false,
        "stack": false,
        "percentage": false,
        "legend": {
          "show": true,
          "values": false,
          "min": false,
          "max": false,
          "current": false,
          "avg": false,
          "alignAsTable": false
        },
        "fill": 1,
        "fillGradient": 0,
        "nullPointMode": "null",
        "steppedLine": false,
        "tooltip": {
          "value_type": "cumulative",
          "shared": true
        }
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "container_memory_usage_bytes{pod=~\"backend-.*|frontend-.*|admin-frontend-.*\"}",
            "legendFormat": "{{pod}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "lines": true,
        "linewidth": 2,
        "points": false,
        "pointradius": 2,
        "bars": false,
        "stack": false,
        "percentage": false,
        "legend": {
          "show": true,
          "values": false,
          "min": false,
          "max": false,
          "current": false,
          "avg": false,
          "alignAsTable": false
        },
        "fill": 1,
        "fillGradient": 0,
        "nullPointMode": "null",
        "steppedLine": false,
        "tooltip": {
          "value_type": "cumulative",
          "shared": true
        },
        "yAxes": [
          {
            "label": "Bytes",
            "show": true,
            "logBase": 1,
            "min": 0,
            "max": null,
            "format": "bytes"
          }
        ]
      },
      {
        "id": 6,
        "title": "Database Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "Active connections"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "lines": true,
        "linewidth": 2,
        "points": false,
        "pointradius": 2,
        "bars": false,
        "stack": false,
        "percentage": false,
        "legend": {
          "show": true,
          "values": false,
          "min": false,
          "max": false,
          "current": false,
          "avg": false,
          "alignAsTable": false
        },
        "fill": 1,
        "fillGradient": 0,
        "nullPointMode": "null",
        "steppedLine": false,
        "tooltip": {
          "value_type": "cumulative",
          "shared": true
        }
      },
      {
        "id": 7,
        "title": "Pod Status",
        "type": "stat",
        "targets": [
          {
            "expr": "kube_pod_info{namespace=\"epsx\"}",
            "legendFormat": "{{pod}}"
          }
        ],
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 24},
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ],
            "fields": ""
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 80
                }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s"
  }
}