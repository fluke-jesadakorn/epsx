# NOTE: Shared variables (Firebase, MusePay, JWT secret) are loaded from /.env.shared
# This file contains only frontend specific environment variables

# Environment
PORT=3000
NODE_ENV=development

# Site URL configuration (server-side only)
SITE_URL=https://epsx.com

# Backend API Configuration
BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000

# OIDC Configuration (Development)
OIDC_CLIENT_ID=epsx-frontend
OIDC_CLIENT_SECRET=your-frontend-client-secret


