{
  "name": "epsx-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "EPSX Trading Platform Frontend - Standalone Application",
  "homepage": "https://epsx.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/fluke-jesadakorn/epsx-frontend"
  },
  "author": "EPSX Team <support@epsx.io>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "next dev -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:web3": "playwright test --project=web3-comprehensive",
    "test:web3:coverage": "./__test__/scripts/run-web3-coverage.sh",
    "test:web3:complete": "playwright test --project=web3-complete-coverage",
    "test:web3:auth": "playwright test --project=web3-auth-flows",
    "test:web3:mobile": "playwright test --project=web3-mobile-chrome --project=web3-mobile-safari",
    "test:web3:cross-browser": "playwright test --project=web3-firefox --project=web3-webkit",
    "analyze": "ANALYZE=true npm run build",
    "clean": "rm -rf .next out dist node_modules/.cache"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.1",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.1",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.89.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "cookies-next": "6.0.0",
    "date-fns": "^3.6.0",
    "jose": "^5.2.3",
    "lucide-react": "0.536.0",
    "next": "15.5.2",
    "next-themes": "0.4.6",
    "qrcode.react": "^4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.58.1",
    "siwe": "^2.0.0",
    "sonner": "2.0.5",
    "swr": "2.3.3",
    "tailwind-merge": "^3.0.2",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0",
    "zod": "4.0.15",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@next/bundle-analyzer": "^15.4.3",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "24.0.3",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.2.3",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-playwright": "^2.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.3.0",
    "pino-pretty": "^13.1.1",
    "playwright": "^1.55.0",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
