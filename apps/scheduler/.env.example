# Server Configuration
PORT=3003
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_NAME=epsx-scheduler

# Cron Configuration
MARKET_DATA_UPDATE_INTERVAL=*/30 * * * *  # Every 30 minutes
NEWS_UPDATE_INTERVAL=0 */6 * * *          # Every 6 hours
CLEANUP_INTERVAL=0 0 * * *                # Daily at midnight

# Gateway Service Configuration
GATEWAY_SERVICE_HOST=localhost
GATEWAY_SERVICE_PORT=3000

# Market Service Configuration
MARKET_SERVICE_HOST=localhost
MARKET_SERVICE_PORT=3001

# Queue Configuration
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT=300000                        # 5 minutes in milliseconds
