# Production Environment Configuration
# Backend API (api.epsx.com)

# Server Configuration
PORT=8080
HOST=0.0.0.0
BIND_ADDRESS=0.0.0.0
DEFAULT_HOST=0.0.0.0
FRONTEND_URL=https://epsx.io
ADMIN_FRONTEND_URL=https://admin.epsx.io
PRODUCTION_FRONTEND_URL=https://epsx.io
PRODUCTION_ADMIN_URL=https://admin.epsx.io
RUST_ENV=production
NODE_ENV=production
ENV=production

# Database Configuration (Recommended: Neon PostgreSQL for serverless)
DATABASE_URL=postgres://neondb_owner:npg_UYc6GMDJfPk8@ep-sweet-wave-a1fnijbf-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT Security Configuration (must match frontend for cross-app auth)
NEXTAUTH_SECRET=your-production-jwt-secret-32-chars-minimum

# Payment Configuration
MUSEPAY_PARTNER_ID=your-partner-id
MUSEPAY_PRIVATE_KEY=your-private-key-multiline
PAYMENT_WEBHOOK_URL=https://api.epsx.io/api/v1/webhook/musepay

# Firebase Configuration
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=your-private-key-multiline
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# Cookie Security Configuration
COOKIE_SIGNING_KEY=your-production-signing-key-32-chars-minimum
COOKIE_ENCRYPTION_KEY=your-production-encryption-key-64-chars-hex-minimum

# Logging Configuration
LOG_LEVEL=info
RUST_LOG=info

# OpenID Connect Client Credentials
OIDC_FRONTEND_CLIENT_ID=epsx-frontend
OIDC_FRONTEND_CLIENT_SECRET=your-production-frontend-client-secret
OIDC_ADMIN_CLIENT_ID=epsx-admin
OIDC_ADMIN_CLIENT_SECRET=your-production-admin-client-secret

# OIDC Provider Configuration
OIDC_ISSUER=https://api.epsx.io
OIDC_AUTHORIZATION_ENDPOINT=/oauth/authorize
OIDC_TOKEN_ENDPOINT=/oauth/token
OIDC_USERINFO_ENDPOINT=/oauth/userinfo
OIDC_JWKS_ENDPOINT=/oauth/jwks