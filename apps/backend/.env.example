# Server Configuration
PORT=8080
RUST_ENV=production
NODE_ENV=production
ENV=production
FRONTEND_URL=https://your-domain.com

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database_name

# Payment Configuration (MusePay)
MUSEPAY_PARTNER_ID=your-partner-id
MUSEPAY_PRIVATE_KEY=your-private-key

# Firebase Admin Configuration
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=your-private-key-multiline
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# TradingView Configuration
TRADINGVIEW_AUTH_TOKEN=your-tradingview-jwt-token

# Redis Configuration (Optional - will use in-memory cache if not provided)
# REDIS_URL=redis://localhost:6379
# REDIS_POOL_SIZE=10

# Cache Configuration
CACHE_TTL_SECONDS=300
PERMISSION_CACHE_TTL=300
# CACHE_MAX_ENTRIES=10000
# CACHE_ENABLE_COMPRESSION=false

# Background Jobs
JOB_SCHEDULER_ENABLED=true
EXPIRATION_CHECK_INTERVAL=3600

# Performance Settings
QUERY_CACHE_SIZE=1000

# Email Configuration
USE_MOCK_EMAIL=true
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging Configuration
LOG_LEVEL=info
RUST_LOG=info