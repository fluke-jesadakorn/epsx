# Authentication
JWT_SECRET=your-jwt-secret-key

# Application URLs and CORS Configuration
BACKEND_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=localhost

# MusePay Configuration
MUSEPAY_PARTNER_ID=your-partner-id
MUSEPAY_PRIVATE_KEY=your-musepay-private-key
MUSEPAY_API_URL=https://api.test.musepay.io/v1/order/pay
