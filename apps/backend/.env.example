# Backend Environment Configuration Example
# Copy this to .env and fill in your values

# Database (Required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/epsx_db

# Redis (Required for notifications)
REDIS_URL=redis://localhost:6379

# Server URLs
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# Authentication (Required)
NEXTAUTH_SECRET=your-secret-32-chars-minimum
JWT_SECRET=epsx-web3-bearer-token-secret-key-change-in-production
OIDC_CLIENT_ID=epsx-frontend
OIDC_CLIENT_SECRET=your-client-secret
OIDC_ADMIN_CLIENT_ID=epsx-admin
OIDC_ADMIN_CLIENT_SECRET=your-admin-secret

# Web3 (Required)
WEB3_APP_SECRET=your-web3-secret-32-chars-minimum
WALLET_SIGNATURE_SECRET=your-wallet-signature-secret-32-chars

# Firebase (Required for legacy auth)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Key-Here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Blockchain
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=testnet
COMPANY_WALLET_MAINNET=0xYourWalletAddress
COMPANY_WALLET_TESTNET=0xYourWalletAddress

# Logging (Optional)
RUST_LOG=info,epsx=debug
LOG_LEVEL=debug

# Environment
ENV=development
RUST_ENV=development
