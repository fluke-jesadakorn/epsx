# Development Environment Configuration
# Backend API (api.epsx.io)

# Server Configuration
PORT=8080
HOST=0.0.0.0
BIND_ADDRESS=0.0.0.0
DEFAULT_HOST=0.0.0.0
FRONTEND_URL=https://epsx.io
ADMIN_FRONTEND_URL=https://admin.epsx.io
PRODUCTION_FRONTEND_URL=https://epsx.io
PRODUCTION_ADMIN_URL=https://admin.epsx.io
RUST_ENV=development
NODE_ENV=development
ENV=development

# Database Configuration (Development)
DATABASE_URL=postgres://user:password@localhost:5432/epsx_dev

# JWT Security Configuration (must match frontend for cross-app auth)
JWT_SECRET=epsx-shared-jwt-secret-2024-cross-app-authentication

# Payment Configuration (Development)
MUSEPAY_PARTNER_ID=dev-partner-id
MUSEPAY_PRIVATE_KEY=dev-private-key
PAYMENT_WEBHOOK_URL=https://api.epsx.io/api/v1/webhook/musepay

# Firebase Configuration (Development)
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=epsx-dev
FIREBASE_API_KEY=dev-firebase-api-key
FIREBASE_PRIVATE_KEY_ID=dev-private-key-id
FIREBASE_PRIVATE_KEY=dev-private-key-multiline
FIREBASE_CLIENT_EMAIL=dev-service-account@epsx-dev.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=dev-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/dev-service-account%40epsx-dev.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# Cookie Security Configuration
COOKIE_SIGNING_KEY=dev-signing-key-32-chars-minimum
COOKIE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Logging Configuration
LOG_LEVEL=debug
RUST_LOG=debug

# OpenID Connect Client Credentials
OIDC_FRONTEND_CLIENT_ID=epsx-frontend
OIDC_FRONTEND_CLIENT_SECRET=dev-frontend-client-secret
OIDC_ADMIN_CLIENT_ID=epsx-admin
OIDC_ADMIN_CLIENT_SECRET=dev-admin-client-secret

# OIDC Provider Configuration
OIDC_ISSUER=https://api.epsx.io
OIDC_AUTHORIZATION_ENDPOINT=/oauth/authorize
OIDC_TOKEN_ENDPOINT=/oauth/token
OIDC_USERINFO_ENDPOINT=/oauth/userinfo
OIDC_JWKS_ENDPOINT=/oauth/jwks