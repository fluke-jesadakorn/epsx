# Application
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/epsx

# Firebase Admin Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
MAX_CONNECTION_EVENTS=100

# Security
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret
COOKIE_DOMAIN=localhost

# Logging
LOG_LEVEL=debug
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/app.log

# Feature Flags
ENABLE_SCRAPING=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_CACHING=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_ITEMS=1000

# External Services
MARKET_DATA_API_KEY=your-api-key
MARKET_DATA_API_URL=https://api.example.com

# Documentation
SWAGGER_ENABLED=true
SWAGGER_TITLE=EPSX API
SWAGGER_DESCRIPTION="EPSX Backend API Documentation"
SWAGGER_VERSION=1.0
SWAGGER_PATH=api

# Monitoring
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true
SENTRY_DSN=your-sentry-dsn

# Testing
TEST_MONGODB_URI=mongodb://localhost:27017/epsx_test

# Comments:
# - Replace all placeholder values with your actual configuration
# - Keep sensitive information secure and never commit actual values
# - Use different values for different environments (dev/staging/prod)
# - Consider using a secrets management service in production
