# NOTE: Shared variables (Firebase, MusePay, JWT secret) are loaded from /.env.shared
# This file contains only backend specific environment variables

# Server Configuration
PORT=8080
HOST=0.0.0.0
BIND_ADDRESS=0.0.0.0
DEFAULT_HOST=127.0.0.1
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
PRODUCTION_FRONTEND_URL=https://epsx.com
PRODUCTION_ADMIN_URL=https://admin.epsx.com
RUST_ENV=development
NODE_ENV=development
ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/epsx_db

# Payment Configuration (Backend-specific)
PAYMENT_WEBHOOK_URL=http://localhost:3000/api/v1/webhook/musepay

# Cookie Security Configuration (Backend-specific)
COOKIE_SIGNING_KEY=your-signing-key-32-chars-minimum

# Logging Configuration
LOG_LEVEL=info
RUST_LOG=info

# OpenID Connect Client Credentials
OIDC_FRONTEND_CLIENT_ID=epsx-frontend
OIDC_FRONTEND_CLIENT_SECRET=your-frontend-client-secret
OIDC_ADMIN_CLIENT_ID=epsx-admin
OIDC_ADMIN_CLIENT_SECRET=your-admin-client-secret

# OIDC Provider Configuration
OIDC_ISSUER=http://localhost:8080
OIDC_AUTHORIZATION_ENDPOINT=/oauth/authorize
OIDC_TOKEN_ENDPOINT=/oauth/token
OIDC_USERINFO_ENDPOINT=/oauth/userinfo
OIDC_JWKS_ENDPOINT=/oauth/jwks

# Test User Configuration (Development Only)
TEST_ADMIN_EMAIL=your-admin@example.com