// Handler implementations

/// Create a new plan with context-specific features
pub async fn create_plan_handler(
    State(state): State<AppState>,
    Json(request): Json<CreatePlanRequest>,
) -> Result<JsonResponse<PlanResponse>, StatusCode> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Start transaction for atomic plan creation
    let result = tokio::task::spawn_blocking(move || {
        conn.transaction::<_, diesel::result::Error, _>(|conn| {
            // Insert the base plan
            // Store additional plan data in the features JSON field
            let plan_features = serde_json::json!({
                "description": request.description,
                "plan_category": request.plan_category,
                "target_audience": request.target_audience, 
                "billing_model": request.billing_model,
                "metadata": request.metadata,
                "features": request.features
            });
            
            let new_plan = diesel::insert_into(pricing_plans::table)
                .values((
                    pricing_plans::name.eq(&request.name),
                    pricing_plans::plan_type.eq(&request.plan_type),
                    pricing_plans::base_price.eq(&request.current_price),
                    pricing_plans::current_price.eq(&request.current_price),
                    pricing_plans::currency.eq(&request.currency),
                    pricing_plans::features.eq(&plan_features),
                    pricing_plans::is_active.eq(Some(true)),
                ))
                .returning(pricing_plans::id)
                .get_result::<i32>(conn)?;

            // Note: Plan features are now stored in the JSON features field above

            Ok(new_plan)
        })
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Fetch the created plan with all details
    let plan_response = get_plan_by_id(&state, result).await
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tracing::info!(
        plan_id = result,
        plan_name = %request.name,
        features_count = request.features.len(),
        "Admin created new dynamic plan"
    );

    Ok(JsonResponse(plan_response))
}

/// Get plan details by ID with features and analytics
pub async fn get_plan_handler(
    State(state): State<AppState>,
    Path(plan_id): Path<i32>,
) -> Result<JsonResponse<PlanResponse>, StatusCode> {
    let plan_response = get_plan_by_id(&state, plan_id).await
        .map_err(|_| StatusCode::NOT_FOUND)?;

    Ok(JsonResponse(plan_response))
}

/// List all plans with filtering and pagination
pub async fn list_plans_handler(
    State(state): State<AppState>,
    Query(query): Query<PlanListQuery>,
) -> Result<JsonResponse<PlanListResponse>, StatusCode> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let limit = query.limit.unwrap_or(20).min(100) as i64;
    let offset = query.offset.unwrap_or(0) as i64;

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    let result = tokio::task::spawn_blocking(move || {
        let mut plan_query = pricing_plans::table.into_boxed();

        // Apply filters - using existing schema fields only
        if let Some(active) = query.is_active {
            plan_query = plan_query.filter(pricing_plans::is_active.eq(Some(active)));
        }

        // Get total count
        let total_count = plan_query.clone().count().get_result::<i64>(&mut *conn)?;

        // Get plans with pagination
        let plans: Vec<(i32, String, String, Decimal, Decimal, String, serde_json::Value, Option<bool>, Option<DateTime<Utc>>, Option<DateTime<Utc>>)> = plan_query
            .limit(limit)
            .offset(offset)
            .select((
                pricing_plans::id,
                pricing_plans::name,
                pricing_plans::plan_type,
                pricing_plans::base_price,
                pricing_plans::current_price,
                pricing_plans::currency,
                pricing_plans::features,
                pricing_plans::is_active,
                pricing_plans::created_at,
                pricing_plans::updated_at,
            ))
            .load(&mut *conn)?;

        // Get subscriber counts for each plan
        let mut plan_responses = Vec::new();
        for (id, name, plan_type, base_price, current_price, currency, features_json, is_active, created_at, updated_at) in plans {
            // Extract additional data from JSON features field
            let description = features_json.get("description")
                .and_then(|v| v.as_str())
                .map(|s| s.to_string());
            let plan_category = features_json.get("plan_category")
                .and_then(|v| v.as_str())
                .unwrap_or("standard")
                .to_string();
            let target_audience = features_json.get("target_audience")
                .and_then(|v| v.as_str())
                .unwrap_or("web_users")
                .to_string();
            let billing_model = features_json.get("billing_model")
                .and_then(|v| v.as_str())
                .unwrap_or("subscription")
                .to_string();
            let metadata = features_json.get("metadata").cloned();
            
            // Mock subscriber count since user_plan_subscriptions table doesn't exist yet
            let subscriber_count = 0i64;

            plan_responses.push(PlanResponse {
                id,
                name,
                description,
                plan_type,
                current_price,
                currency,
                target_audience,
                billing_model,
                plan_category,
                is_active: is_active.unwrap_or(false),
                features: vec![], // Will be populated separately if needed
                metadata,
                created_at: created_at.unwrap_or_else(|| Utc::now()),
                updated_at,
                subscriber_count: subscriber_count as u64,
                revenue_last_30_days: Decimal::ZERO, // TODO: Calculate from usage events
            });
        }

        Ok((plan_responses, total_count as u32))
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    let (plans, total_count) = result;
    let has_more = (offset + limit) < total_count as i64;

    Ok(JsonResponse(PlanListResponse {
        plans,
        total_count,
        has_more,
    }))
}

/// Update plan details and features
pub async fn update_plan_handler(
    State(state): State<AppState>,
    Path(plan_id): Path<i32>,
    Json(request): Json<UpdatePlanRequest>,
) -> Result<JsonResponse<PlanResponse>, StatusCode> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    let result = tokio::task::spawn_blocking(move || {
        conn.transaction::<_, diesel::result::Error, _>(|conn| {
            // Update base plan fields
            let mut plan_changeset = pricing_plans::table.filter(pricing_plans::id.eq(plan_id));
            
            if let Some(name) = &request.name {
                plan_changeset = plan_changeset.filter(pricing_plans::name.ne(name)); // This is incorrect, let me fix the update query
            }

            // Let's use diesel's update syntax properly
            // Get current plan to merge with updates
            let current_plan: (serde_json::Value, Option<bool>) = pricing_plans::table
                .filter(pricing_plans::id.eq(plan_id))
                .select((pricing_plans::features, pricing_plans::is_active))
                .first(conn)?;
            
            let mut features_json = current_plan.0;
            let mut updates_made = false;
            
            // Update basic fields
            if let Some(name) = &request.name {
                diesel::update(pricing_plans::table.filter(pricing_plans::id.eq(plan_id)))
                    .set(pricing_plans::name.eq(name))
                    .execute(conn)?;
                updates_made = true;
            }
            if let Some(price) = &request.current_price {
                diesel::update(pricing_plans::table.filter(pricing_plans::id.eq(plan_id)))
                    .set((pricing_plans::current_price.eq(price), pricing_plans::base_price.eq(price)))
                    .execute(conn)?;
                updates_made = true;
            }
            if let Some(is_active) = request.is_active {
                diesel::update(pricing_plans::table.filter(pricing_plans::id.eq(plan_id)))
                    .set(pricing_plans::is_active.eq(Some(is_active)))
                    .execute(conn)?;
                updates_made = true;
            }
            
            // Update JSON fields
            if let Some(description) = &request.description {
                features_json["description"] = serde_json::Value::String(description.clone());
                updates_made = true;
            }
            if let Some(metadata) = &request.metadata {
                features_json["metadata"] = metadata.clone();
                updates_made = true;
            }
            
            // Update features JSON if any changes were made
            if updates_made {
                diesel::update(pricing_plans::table.filter(pricing_plans::id.eq(plan_id)))
                    .set(pricing_plans::features.eq(&features_json))
                    .execute(conn)?;
            }

            // Update features if provided (stored in JSON)
            if let Some(features) = &request.features {
                features_json["features"] = serde_json::to_value(features).unwrap_or(serde_json::json!([]));
                diesel::update(pricing_plans::table.filter(pricing_plans::id.eq(plan_id)))
                    .set(pricing_plans::features.eq(&features_json))
                    .execute(conn)?;
            }

            Ok(())
        })
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Return updated plan
    let plan_response = get_plan_by_id(&state, plan_id).await
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tracing::info!(
        plan_id = plan_id,
        "Admin updated dynamic plan"
    );

    Ok(JsonResponse(plan_response))
}

/// Delete/deactivate a plan
pub async fn delete_plan_handler(
    State(state): State<AppState>,
    Path(plan_id): Path<i32>,
) -> Result<JsonResponse<serde_json::Value>, StatusCode> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tokio::task::spawn_blocking(move || {
        // Don't actually delete - just deactivate to preserve data integrity
        diesel::update(pricing_plans::table.filter(pricing_plans::id.eq(plan_id)))
            .set(pricing_plans::is_active.eq(false))
            .execute(&mut *conn)
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tracing::warn!(
        plan_id = plan_id,
        "Admin deactivated plan"
    );

    Ok(JsonResponse(serde_json::json!({
        "message": "Plan deactivated successfully",
        "plan_id": plan_id
    })))
}

