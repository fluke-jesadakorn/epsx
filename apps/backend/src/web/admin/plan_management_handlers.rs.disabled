    pub average_requests_per_subscriber: f64,
    pub peak_usage_time: DateTime<Utc>,
    pub resource_utilization_percentage: f64,
    pub top_endpoints: Vec<EndpointUsage>,
}

#[derive(Debug, Serialize)]
pub struct EndpointUsage {
