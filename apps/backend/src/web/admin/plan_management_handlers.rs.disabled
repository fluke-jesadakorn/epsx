    };

    Ok(JsonResponse(analytics))
}

// Helper functions

async fn get_plan_by_id(state: &AppState, plan_id: i32) -> Result<PlanResponse, Box<dyn std::error::Error + Send + Sync>> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let mut conn = state.db_pool.get()?;

    tokio::task::spawn_blocking(move || {
        // Get plan details using existing schema
        let (id, name, plan_type, base_price, current_price, currency, features_json, is_active, created_at, updated_at): (i32, String, String, Decimal, Decimal, String, serde_json::Value, Option<bool>, Option<chrono::DateTime<chrono::Utc>>, Option<chrono::DateTime<chrono::Utc>>) = pricing_plans::table
            .filter(pricing_plans::id.eq(plan_id))
            .select((
                pricing_plans::id,
                pricing_plans::name,
                pricing_plans::plan_type,
                pricing_plans::base_price,
                pricing_plans::current_price,
                pricing_plans::currency,
                pricing_plans::features,
                pricing_plans::is_active,
                pricing_plans::created_at,
                pricing_plans::updated_at,
            ))
            .first(&mut *conn)?;

        // Extract plan features from JSON field
        let feature_responses: Vec<PlanFeatureResponse> = if let Some(features_array) = features_json.get("features").and_then(|v| v.as_array()) {
            features_array.iter().enumerate().map(|(index, feature)| {
                PlanFeatureResponse {
                    id: index as i32, // Mock ID
                    context_name: feature.get("context_name")
                        .and_then(|v| v.as_str())
                        .unwrap_or("web_app")
                        .to_string(),
                    feature_key: feature.get("feature_key")
                        .and_then(|v| v.as_str())
                        .unwrap_or("unknown")
                        .to_string(),
                    feature_config: feature.get("feature_config")
                        .cloned()
                        .unwrap_or(serde_json::json!({})),
                    resource_cost: feature.get("resource_cost")
                        .and_then(|v| v.as_str())
                        .and_then(|s| s.parse().ok())
                        .unwrap_or(Decimal::ZERO),
                    is_active: feature.get("is_active")
                        .and_then(|v| v.as_bool())
                        .unwrap_or(true),
                }
            }).collect()
        } else {
            vec![]
        };

        // Extract data from JSON features field
        let description = features_json.get("description")
            .and_then(|v| v.as_str())
            .map(|s| s.to_string());
        let target_audience = features_json.get("target_audience")
            .and_then(|v| v.as_str())
            .unwrap_or("web_users")
            .to_string();
        let billing_model = features_json.get("billing_model")
            .and_then(|v| v.as_str())
            .unwrap_or("subscription")
            .to_string();
        let plan_category = features_json.get("plan_category")
            .and_then(|v| v.as_str())
            .unwrap_or("standard")
            .to_string();
        let metadata = features_json.get("metadata").cloned();

        // Mock subscriber count since table doesn't exist yet
        let subscriber_count: i64 = 0;

        Ok(PlanResponse {
            id,
            name,
            description,
            plan_type,
            current_price,
            currency,
            target_audience,
            billing_model,
            plan_category,
            is_active: is_active.unwrap_or(false),
            features: feature_responses,
            metadata,
            created_at: created_at.unwrap_or_else(|| Utc::now()),
            updated_at,
            subscriber_count: subscriber_count as u64,
            revenue_last_30_days: Decimal::ZERO, // TODO: Calculate from usage events
        })
    }).await?
}

async fn get_plan_name(state: &AppState, plan_id: i32) -> Result<String, Box<dyn std::error::Error + Send + Sync>> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let mut conn = state.db_pool.get()?;

    let plan_name = tokio::task::spawn_blocking(move || {
        pricing_plans::table
            .filter(pricing_plans::id.eq(plan_id))
            .select(pricing_plans::name)
            .first::<String>(&mut *conn)
    }).await??;

    Ok(plan_name)
}

// Subscription Management Handlers

/// Create a new subscription for a user
pub async fn create_subscription_handler(
    State(_state): State<AppState>,
    Json(request): Json<CreateSubscriptionRequest>,
) -> Result<JsonResponse<SubscriptionResponse>, StatusCode> {
    // Mock implementation - return success response
    let subscription_id = uuid::Uuid::new_v4();
    
    // Generate API key if needed
    let api_key = if request.access_context == "external" {
        Some(generate_api_key())
    } else {
        None
    };

    // Create mock subscription response
    let subscription_response = SubscriptionResponse {
        id: subscription_id.to_string(),
        user_id: request.user_id.clone(),
        plan_id: request.plan_id,
        access_context: request.access_context.clone(),
        api_key: api_key.clone(),
        api_key_name: request.api_key_name.clone(),
        status: "active".to_string(),
        expires_at: request.expires_at.clone(),
        auto_renew: request.auto_renew,
        created_at: Utc::now(),
        updated_at: Utc::now(),
        metadata: request.metadata.clone(),
        plan_name: "Mock Plan".to_string(),
        current_usage: serde_json::json!({}),
        quota_limits: serde_json::json!({}),
    };

    tracing::info!(
        subscription_id = %subscription_id,
        user_id = %request.user_id,
        plan_id = request.plan_id,
        access_context = %request.access_context,
        "Admin created new subscription (mock)"
    );

    Ok(JsonResponse(subscription_response))
}

/// List subscriptions with filtering
pub async fn list_subscriptions_handler(
    State(state): State<AppState>,
    Query(query): Query<HashMap<String, String>>,
) -> Result<JsonResponse<Vec<SubscriptionResponse>>, StatusCode> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let limit = query.get("limit")
        .and_then(|l| l.parse::<i64>().ok())
        .unwrap_or(50)
        .min(100);

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    let result = tokio::task::spawn_blocking(move || {
        let mut subscription_query = user_plan_subscriptions::table
            .inner_join(pricing_plans::table)
            .into_boxed();

        // Apply filters
        if let Some(status) = query.get("status") {
            subscription_query = subscription_query.filter(user_plan_subscriptions::status.eq(status));
        }
        if let Some(access_context) = query.get("access_context") {
            subscription_query = subscription_query.filter(user_plan_subscriptions::access_context.eq(access_context));
        }
        if let Some(plan_id_str) = query.get("plan_id") {
            if let Ok(plan_id) = plan_id_str.parse::<i32>() {
                subscription_query = subscription_query.filter(user_plan_subscriptions::plan_id.eq(plan_id));
            }
        }

        let subscriptions: Vec<(uuid::Uuid, uuid::Uuid, i32, String, Option<String>, Option<String>, String, Option<DateTime<Utc>>, bool, DateTime<Utc>, Option<serde_json::Value>, String)> = subscription_query
            .limit(limit)
            .select((
                user_plan_subscriptions::id,
                user_plan_subscriptions::user_id,
                user_plan_subscriptions::plan_id,
                user_plan_subscriptions::access_context,
                user_plan_subscriptions::api_key,
                user_plan_subscriptions::api_key_name,
                user_plan_subscriptions::status,
                user_plan_subscriptions::expires_at,
                user_plan_subscriptions::auto_renew,
                user_plan_subscriptions::created_at,
                user_plan_subscriptions::subscription_metadata,
                pricing_plans::name,
            ))
            .load(&mut *conn)?;

        let subscription_responses: Vec<SubscriptionResponse> = subscriptions.into_iter()
            .map(|(id, user_id, plan_id, access_context, api_key, api_key_name, status, expires_at, auto_renew, created_at, metadata, plan_name)| {
                SubscriptionResponse {
                    id: id.to_string(),
                    user_id: user_id.to_string(),
                    plan_id,
                    plan_name,
                    access_context,
                    api_key,
                    api_key_name,
                    status,
                    current_usage: serde_json::json!({}), // TODO: Fetch real usage
                    quota_limits: serde_json::json!({}),  // TODO: Fetch real limits
                    started_at: created_at,
                    expires_at,
                    auto_renew,
                    last_billed_at: None, // TODO: Fetch from billing records
                    next_billing_date: None, // TODO: Calculate next billing
                    created_at,
                    metadata,
                }
            })
            .collect();

        Ok(subscription_responses)
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    Ok(JsonResponse(result))
}

/// Update subscription details
pub async fn update_subscription_handler(
    State(state): State<AppState>,
    Path(subscription_id): Path<String>,
    Json(request): Json<UpdateSubscriptionRequest>,
) -> Result<JsonResponse<SubscriptionResponse>, StatusCode> {
    // Note: user_plan_subscriptions table needs migration - using mock data
    use diesel::prelude::*;

    let subscription_uuid = uuid::Uuid::parse_str(&subscription_id)
        .map_err(|_| StatusCode::BAD_REQUEST)?;

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tokio::task::spawn_blocking(move || {
        let mut update_query = diesel::update(
            user_plan_subscriptions::table.filter(user_plan_subscriptions::id.eq(subscription_uuid))
        );

        if let Some(status) = &request.status {
            update_query = update_query.set(user_plan_subscriptions::status.eq(status));
        }
        if let Some(plan_id) = request.plan_id {
            update_query = update_query.set(user_plan_subscriptions::plan_id.eq(plan_id));
        }
        if let Some(expires_at) = request.expires_at {
            update_query = update_query.set(user_plan_subscriptions::expires_at.eq(expires_at));
        }
        if let Some(auto_renew) = request.auto_renew {
            update_query = update_query.set(user_plan_subscriptions::auto_renew.eq(auto_renew));
        }

        update_query.execute(&mut *conn)
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Return updated subscription
    let subscription_response = get_subscription_by_id(&state, &subscription_id).await
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tracing::info!(
        subscription_id = %subscription_id,
        "Admin updated subscription"
    );

    Ok(JsonResponse(subscription_response))
}

/// Get subscription details
pub async fn get_subscription_handler(
    State(state): State<AppState>,
    Path(subscription_id): Path<String>,
) -> Result<JsonResponse<SubscriptionResponse>, StatusCode> {
    let subscription_response = get_subscription_by_id(&state, &subscription_id).await
        .map_err(|_| StatusCode::NOT_FOUND)?;

    Ok(JsonResponse(subscription_response))
}

/// Cancel/delete subscription
pub async fn cancel_subscription_handler(
    State(state): State<AppState>,
    Path(subscription_id): Path<String>,
) -> Result<JsonResponse<serde_json::Value>, StatusCode> {
    // Note: user_plan_subscriptions table needs migration - using mock data
    use diesel::prelude::*;

    let subscription_uuid = uuid::Uuid::parse_str(&subscription_id)
        .map_err(|_| StatusCode::BAD_REQUEST)?;

    let mut conn = state.db_pool.get()
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tokio::task::spawn_blocking(move || {
        diesel::update(
            user_plan_subscriptions::table.filter(user_plan_subscriptions::id.eq(subscription_uuid))
        )
        .set(user_plan_subscriptions::status.eq("canceled"))
        .execute(&mut *conn)
    }).await
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?
    .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    tracing::info!(
        subscription_id = %subscription_id,
        "Admin canceled subscription"
    );

    Ok(JsonResponse(serde_json::json!({
        "message": "Subscription canceled successfully",
        "subscription_id": subscription_id
    })))
}

// Helper functions for subscriptions

async fn get_subscription_by_id(
    state: &AppState,
    subscription_id: &str,
) -> Result<SubscriptionResponse, Box<dyn std::error::Error + Send + Sync>> {
    use crate::infrastructure::adapters::repositories::diesel::schema::pricing_plans;
    use diesel::prelude::*;

    let subscription_uuid = uuid::Uuid::parse_str(subscription_id)?;
    let mut conn = state.db_pool.get()?;

    let result = tokio::task::spawn_blocking(move || {
        user_plan_subscriptions::table
            .inner_join(pricing_plans::table)
            .filter(user_plan_subscriptions::id.eq(subscription_uuid))
            .select((
                user_plan_subscriptions::id,
                user_plan_subscriptions::user_id,
                user_plan_subscriptions::plan_id,
                user_plan_subscriptions::access_context,
                user_plan_subscriptions::api_key,
                user_plan_subscriptions::api_key_name,
                user_plan_subscriptions::status,
                user_plan_subscriptions::expires_at,
                user_plan_subscriptions::auto_renew,
                user_plan_subscriptions::created_at,
                user_plan_subscriptions::subscription_metadata,
                pricing_plans::name,
            ))
            .first::<(uuid::Uuid, uuid::Uuid, i32, String, Option<String>, Option<String>, String, Option<DateTime<Utc>>, bool, DateTime<Utc>, Option<serde_json::Value>, String)>(&mut *conn)
    }).await??;

    let (id, user_id, plan_id, access_context, api_key, api_key_name, status, expires_at, auto_renew, created_at, metadata, plan_name) = result;

    Ok(SubscriptionResponse {
        id: id.to_string(),
        user_id: user_id.to_string(),
        plan_id,
        plan_name,
        access_context,
        api_key,
        api_key_name,
        status,
        current_usage: serde_json::json!({}), // TODO: Fetch real usage data
        quota_limits: serde_json::json!({}),  // TODO: Fetch real quota data
        started_at: created_at,
        expires_at,
        auto_renew,
        last_billed_at: None, // TODO: Fetch from billing records
        next_billing_date: None, // TODO: Calculate next billing date
        created_at,
        metadata,
    })
}

fn generate_api_key() -> String {
    use rand::Rng;
    use rand::distributions::Alphanumeric;
    
    let api_key: String = rand::thread_rng()
        .sample_iter(&Alphanumeric)
        .take(32)
        .map(char::from)
        .collect();
    
    format!("epsx_live_{}", api_key)
}