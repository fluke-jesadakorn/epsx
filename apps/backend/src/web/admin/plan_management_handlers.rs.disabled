    // Get plan name first
    let plan_name = get_plan_name(&state, plan_id).await
        .map_err(|_| StatusCode::NOT_FOUND)?;

    // Generate analytics (simplified implementation for now)
    let analytics = PlanAnalyticsResponse {
        plan_id,
        plan_name,
        analytics_period: period,
        subscriber_metrics: SubscriberMetrics {
            total_subscribers: 0,
            new_subscribers_this_period: 0,
            churned_subscribers_this_period: 0,
            subscriber_growth_rate: 0.0,
            subscriber_distribution_by_context: HashMap::new(),
        },
        usage_metrics: UsageMetrics {
            total_api_calls: 0,
            total_data_transfer_gb: 0.0,
            average_requests_per_subscriber: 0.0,
            peak_usage_time: Utc::now(),
            resource_utilization_percentage: 0.0,
            top_endpoints: vec![],
        },
        revenue_metrics: RevenueMetrics {
            total_revenue: Decimal::ZERO,
            revenue_growth_rate: 0.0,
            average_revenue_per_user: Decimal::ZERO,
            revenue_by_feature: HashMap::new(),
            projected_monthly_revenue: Decimal::ZERO,
        },
        performance_metrics: PerformanceMetrics {
            plan_efficiency_score: 1.0,
            cost_per_request: Decimal::ZERO,
            profit_margin: 0.0,
            rate_limit_hit_rate: 0.0,
            overage_usage_rate: 0.0,
        },
        recommendations: vec![
            PlanRecommendation {
                recommendation_type: "optimization".to_string(),
                priority: "medium".to_string(),
                title: "Consider adding burst capacity".to_string(),
                description: "Current usage patterns suggest subscribers would benefit from higher burst limits".to_string(),
                suggested_action: Some("Increase burst_multiplier to 1.5".to_string()),
                potential_impact: Some("Could reduce rate limit violations by 30%".to_string()),
            }
