{
  "name": "@epsx/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- cargo watch --why --exec 'run'",
    "dev:backend": "dotenv -e ../../.env -- cargo watch --why --exec 'run'",
    "dev:debug": "dotenv -e ../../.env -- RUST_LOG=debug cargo watch --why --exec 'run'",
    "kill-port": "lsof -ti:8080 | xargs kill -9 2>/dev/null || true",
    "cleanup": "lsof -ti:8080 | xargs kill -9 2>/dev/null || echo 'Port cleaned, ready for restart'",
    "build": "dotenv -e ../../.env -- cargo build --release",
    "build:backend": "dotenv -e ../../.env -- cargo build --release",
    "start": "dotenv -e ../../.env -- cargo run --release",
    "start:backend": "dotenv -e ../../.env -- cargo run --release",
    "clean": "cargo clean",
    "test": "dotenv -e ../../.env -- cargo test",
    "test:backend": "dotenv -e ../../.env -- cargo test",
    "test:watch": "dotenv -e ../../.env -- cargo watch --why --exec 'test'",
    "test:coverage": "dotenv -e ../../.env -- cargo tarpaulin --out html --output-dir coverage",
    "bench": "cargo bench",
    "lint": "cargo clippy",
    "lint:fix": "cargo clippy --fix --allow-dirty --allow-staged",
    "migrate:all": "./scripts/migrate_all.sh"
  }
}