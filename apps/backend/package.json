{
  "name": "@epsx/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ENV=development sh ../../scripts/utils/with-root-env.sh cargo watch --why --exec 'run'",
    "build": "cargo build --release",
    "build:backend": "cargo build --release",
    "start": "NODE_ENV=production sh ../../scripts/utils/with-root-env.sh cargo run --release",
    "clean": "cargo clean",
    "test": "NODE_ENV=test sh ../../scripts/utils/with-root-env.sh cargo test",
    "test:watch": "NODE_ENV=test sh ../../scripts/utils/with-root-env.sh cargo watch --why --exec 'test'",
    "lint": "cargo clippy",
    "lint:fix": "cargo clippy --fix --allow-dirty --allow-staged",
    "migrate:all": "./scripts/migrate_all.sh"
  }
}
