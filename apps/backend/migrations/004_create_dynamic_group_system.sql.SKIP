    ARRAY['epsx:analytics:view', 'epsx:notifications:priority'],
    TRUE,
    '{"conditions": [{"field": "user.behavior_score", "operator": "greater_than", "value": "{engagement_threshold}"}, {"field": "user.active_days", "operator": "greater_than", "value": "{activity_days}"}], "logic_operator": "AND"}',
    'hourly',
    TRUE, TRUE, NULL
),
(
    'Time-Based Access Control',
    'time-based-access',
    'Grants permissions based on time windows and schedules',
