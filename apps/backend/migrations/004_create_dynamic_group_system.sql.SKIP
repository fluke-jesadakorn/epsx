    '{"time_window": {"start": "09:00", "end": "17:00", "days": ["mon", "tue", "wed", "thu", "fri"]}, "timezone": "UTC"}',
    ARRAY['epsx:trading:advanced', 'epsx:analytics:realtime'],
    TRUE,
    '{"conditions": [{"field": "current_time", "operator": "within_window", "value": "{time_window}"}]}',
    'realtime',
    TRUE, TRUE, NULL
),
(
    'Web3 Asset-Based Groups',
    'web3-asset-groups',
    'Automatic group assignment based on Web3 asset ownership',
