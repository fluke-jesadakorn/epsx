    '{"contract_address": {"type": "string", "required": true}, "minimum_balance": {"type": "string", "default": "1"}}',
    '{"minimum_balance": "1"}',
    ARRAY['epsx:web3:premium', 'epsx:governance:vote'],
    TRUE,
    '{"conditions": [{"field": "web3.token_balance", "operator": "greater_than_or_equal", "value": "{minimum_balance}", "contract": "{contract_address}"}]}',
    'daily',
    TRUE, TRUE, NULL
