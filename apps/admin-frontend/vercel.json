{
  "name": "epsx-admin-frontend",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "command": "bun install && bun run build:admin"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL_PACKAGE_MANAGER": "bun"
  }
}
