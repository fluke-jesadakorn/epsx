{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/types/*": [
        "./types/*"
      ],
      "@/context/*": [
        "./context/*"
      ],
      "@/services/*": [
        "./services/*"
      ],
      "@epsx/config/*": [
        "../../packages/config/*"
      ],
      "@epsx/types/*": [
        "../../packages/types/*"
      ],
      "@epsx/utils/*": [
        "../../packages/utils/*"
      ],
      "@epsx/ui": [
        "../../packages/ui/src"
      ],
      "@epsx/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@epsx/api-client": [
        "../../packages/api-client/src"
      ],
      "@epsx/api-client/*": [
        "../../packages/api-client/src/*"
      ],
      "@types/react": [
        "node_modules/@types/react"
      ]
    },
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/types/src/**/*.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build"
  ]
}
