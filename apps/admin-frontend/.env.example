# NOTE: Shared variables (Firebase, MusePay, JWT secret) are loaded from /.env.shared
# This file contains only admin-frontend specific environment variables

# Environment
PORT=3001
NODE_ENV=development

# Admin Site URL configuration (server-side only)
SITE_URL=https://admin.epsx.com

# Backend API Configuration
BACKEND_URL=https://api.epsx.io
NEXT_PUBLIC_BACKEND_URL=https://api.epsx.io

# JWT Authentication Configuration (Admin-specific)
ADMIN_URL=https://admin.epsx.io

# OIDC Configuration (Development)
OIDC_CLIENT_ID=epsx-admin
OIDC_CLIENT_SECRET=your-admin-client-secret
NEXT_PUBLIC_OAUTH_CLIENT_ID=epsx-admin

# Firebase Configuration - Admin SDK handled by backend only
# Only client-side Firebase configs are needed:
# NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key


