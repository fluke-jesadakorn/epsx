rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - readable by authenticated admin users
    match /users/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isAuthorizedToManageUsers();
    }
    
    // Custom permissions - only admins can manage
    match /custom_permissions/{permissionId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isAuthorizedToManagePermissions();
      allow create: if isAdmin() && isAuthorizedToGrantPermissions();
      allow delete: if isAdmin() && isAuthorizedToRevokePermissions();
    }
    
    // Package permissions - readable by admins, system managed
    match /package_permissions/{permissionId} {
      allow read: if isAdmin();
      allow write: if false; // System managed only
    }
    
    // Effective permissions - readable for access checks
    match /effective_permissions/{permissionId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isOwner(resource.data.userId)
      );
      allow write: if isAdmin() && isAuthorizedToManagePermissions();
    }
    
    // Audit logs - readable by admins
    match /permission_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // System managed only
    }
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.isActive == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAuthorizedToManageUsers() {
      // Check if admin has user management permissions
      return hasAdminPermission('users:manage');
    }
    
    function isAuthorizedToManagePermissions() {
      // Check if admin has permission management permissions
      return hasAdminPermission('permissions:manage');
    }
    
    function isAuthorizedToGrantPermissions() {
      return hasAdminPermission('permissions:grant');
    }
    
    function isAuthorizedToRevokePermissions() {
      return hasAdminPermission('permissions:revoke');
    }
    
    function hasAdminPermission(permission) {
      // Simplified permission check - in production, implement proper role/permission checking
      return isAdmin() && (
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'SUPER_ADMIN' ||
        permission in get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.permissions
      );
    }
  }
}
