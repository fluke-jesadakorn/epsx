{
  "name": "epsx-admin-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "EPSX Admin Dashboard - Standalone Application",
  "homepage": "https://admin.epsx.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/fluke-jesadakorn/epsx-admin-frontend"
  },
  "author": "EPSX Team <admin@epsx.io>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev -H 0.0.0.0 -p ${PORT:-3001} --webpack",
    "build": "dotenv -e ../../.env -- next build --webpack",
    "start": "dotenv -e ../../.env -- next start -p ${PORT:-3001}",
    "lint": "dotenv -e ../../.env -- next lint",
    "lint:fix": "dotenv -e ../../.env -- next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "ANALYZE=true npm run build",
    "clean": "rm -rf .next out dist node_modules/.cache"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/pg": "^8.15.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "4.1.0",
    "jose": "6.1.0",
    "lucide-react": "0.543.0",
    "next": "16.0.3",
    "next-themes": "0.4.6",
    "pg": "^8.16.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.1.0",
    "swr": "2.3.3",
    "tailwind-merge": "^3.0.2",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@next/bundle-analyzer": "^15.4.3",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.0.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cookie": "^0.6.0",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "24.0.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.2.3",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^60.8.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "husky": "^9.1.7",
    "jest": "30.1.3",
    "jest-environment-jsdom": "30.1.2",
    "lint-staged": "16.1.6",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
