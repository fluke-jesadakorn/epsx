# Admin Frontend Environment Configuration
# Copy this file to .env.local and configure for your environment

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Firebase Configuration (for Admin Authentication)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# Admin Authentication Configuration
NEXTAUTH_SECRET=your-nextauth-secret-key-for-admin
NEXTAUTH_URL=http://localhost:3001

# Admin-Specific Settings
ADMIN_SESSION_TIMEOUT=3600000
ADMIN_IDLE_TIMEOUT=1800000
ADMIN_ENABLE_AUDIT_LOGGING=true
ADMIN_REQUIRE_MFA=false

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/epsx_db

# Redis Configuration (for admin sessions)
REDIS_URL=redis://localhost:6379

# Security Configuration
ADMIN_ALLOWED_IPS=
ADMIN_ENABLE_IP_VALIDATION=false
ADMIN_ENABLE_DEVICE_FINGERPRINTING=false

# Monitoring and Logging
ADMIN_LOG_LEVEL=info
ADMIN_ENABLE_PERFORMANCE_MONITORING=true
ADMIN_SENTRY_DSN=

# Feature Flags
ADMIN_ENABLE_MULTI_PROVIDER_AUTH=true
ADMIN_ENABLE_CASBIN_AUTHORIZATION=true
ADMIN_ENABLE_REAL_TIME_PERMISSIONS=true

# Development Settings
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1