# Deployer wallet private key (DO NOT commit actual key)
PRIVATE_KEY=your_private_key_here

# BSC RPC URLs (optional - defaults provided)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# BSCScan API key for contract verification
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Gas reporting (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# Admin wallet address (who can manage the contract)
ADMIN_WALLET_ADDRESS=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
