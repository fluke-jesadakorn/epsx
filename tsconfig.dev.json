{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Development-specific overrides for better module resolution
    "baseUrl": ".",
    "paths": {
      // For development: prioritize source over dist for better watch mode compatibility
      "@epsx/types": ["./packages/types/src/index.ts", "./packages/types/dist/index.js"],
      "@epsx/types/*": ["./packages/types/src/*", "./packages/types/dist/*"],
      "@epsx/shared-core": ["./packages/shared-core/src/index.ts", "./packages/shared-core/dist/index.js"],
      "@epsx/shared-core/*": ["./packages/shared-core/src/*", "./packages/shared-core/dist/*"],
      "@epsx/shared-utils": ["./packages/shared-utils/src/index.ts", "./packages/shared-utils/dist/index.js"],
      "@epsx/shared-utils/*": ["./packages/shared-utils/src/*", "./packages/shared-utils/dist/*"],
      "@epsx/ui": ["./packages/ui/src/index.ts", "./packages/ui/dist/index.js"],
      "@epsx/ui/*": ["./packages/ui/src/*", "./packages/ui/dist/*"],
      "@epsx/config": ["./packages/config/src/index.ts", "./packages/config/dist/index.js"],
      "@epsx/config/*": ["./packages/config/src/*", "./packages/config/dist/*"],
      "@epsx/api-client": ["./packages/api-client/src/index.ts", "./packages/api-client/dist/index.js"],
      "@epsx/api-client/*": ["./packages/api-client/src/*", "./packages/api-client/dist/*"],
      "@epsx/server-actions": ["./packages/server-actions/src/index.ts", "./packages/server-actions/dist/index.js"],
      "@epsx/server-actions/*": ["./packages/server-actions/src/*", "./packages/server-actions/dist/*"],
      "@epsx/auth-shared": ["./packages/auth-shared/src/index.ts", "./packages/auth-shared/dist/index.js"],
      "@epsx/auth-shared/*": ["./packages/auth-shared/src/*", "./packages/auth-shared/dist/*"],
      "@epsx/firebase-analytics": ["./packages/firebase-analytics/src/index.ts", "./packages/firebase-analytics/dist/index.js"],
      "@epsx/firebase-analytics/*": ["./packages/firebase-analytics/src/*", "./packages/firebase-analytics/dist/*"],
      "@epsx/server-providers": ["./packages/server-providers/src/index.ts", "./packages/server-providers/dist/index.js"],
      "@epsx/server-providers/*": ["./packages/server-providers/src/*", "./packages/server-providers/dist/*"],
      "@epsx/unified-data-access": ["./packages/unified-data-access/src/index.ts", "./packages/unified-data-access/dist/index.js"],
      "@epsx/unified-data-access/*": ["./packages/unified-data-access/src/*", "./packages/unified-data-access/dist/*"],
      "@epsx/theme": ["./packages/theme"],
      "@epsx/theme/*": ["./packages/theme/*"],
      "@/*": ["./src/*"],
      "~/*": ["./*"]
    },
    // Better module resolution for development
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    // Development-friendly settings
    "incremental": true,
    "composite": false,
    "preserveWatchOutput": true
  }
}