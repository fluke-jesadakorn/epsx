{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "EPSX Monorepo Base Config",
  "compilerOptions": {
    // Language and Environment
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "checkJs": false,

    // Module Resolution
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // Type Checking
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": false,

    // Emit
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "importHelpers": true,

    // Interop Constraints
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,

    // Completeness
    "skipLibCheck": true,

    // Advanced
    "incremental": true,
    "composite": false,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "preserveWatchOutput": true,

    // JSX (for React apps)
    "jsx": "preserve",
    "jsxImportSource": "react",

    // Path Mapping for Monorepo - hybrid approach for robust resolution
    "baseUrl": ".",
    "paths": {
      "@epsx/types": ["./packages/types/src", "./packages/types/dist"],
      "@epsx/types/*": ["./packages/types/src/*", "./packages/types/dist/*"],
      "@epsx/shared-core": ["./packages/shared-core/src", "./packages/shared-core/dist"],
      "@epsx/shared-core/*": ["./packages/shared-core/src/*", "./packages/shared-core/dist/*"],
      "@epsx/shared-utils": ["./packages/shared-utils/src", "./packages/shared-utils/dist"],
      "@epsx/shared-utils/*": ["./packages/shared-utils/src/*", "./packages/shared-utils/dist/*"],
      "@epsx/ui": ["./packages/ui/src", "./packages/ui/dist"],
      "@epsx/ui/*": ["./packages/ui/src/*", "./packages/ui/dist/*"],
      "@epsx/config": ["./packages/config/src", "./packages/config/dist"],
      "@epsx/config/*": ["./packages/config/src/*", "./packages/config/dist/*"],
      "@epsx/api-client": ["./packages/api-client/src", "./packages/api-client/dist"],
      "@epsx/api-client/*": ["./packages/api-client/src/*", "./packages/api-client/dist/*"],
      "@epsx/server-actions": ["./packages/server-actions/src", "./packages/server-actions/dist"],
      "@epsx/server-actions/*": ["./packages/server-actions/src/*", "./packages/server-actions/dist/*"],
      "@epsx/auth-shared": ["./packages/auth-shared/src", "./packages/auth-shared/dist"],
      "@epsx/auth-shared/*": ["./packages/auth-shared/src/*", "./packages/auth-shared/dist/*"],
      "@epsx/firebase-analytics": ["./packages/firebase-analytics/src", "./packages/firebase-analytics/dist"],
      "@epsx/firebase-analytics/*": ["./packages/firebase-analytics/src/*", "./packages/firebase-analytics/dist/*"],
      "@epsx/server-providers": ["./packages/server-providers/src", "./packages/server-providers/dist"],
      "@epsx/server-providers/*": ["./packages/server-providers/src/*", "./packages/server-providers/dist/*"],
      "@epsx/unified-data-access": ["./packages/unified-data-access/src", "./packages/unified-data-access/dist"],
      "@epsx/unified-data-access/*": ["./packages/unified-data-access/src/*", "./packages/unified-data-access/dist/*"],
      "@epsx/theme": ["./packages/theme"],
      "@epsx/theme/*": ["./packages/theme/*"],
      "@/*": ["./src/*"],
      "~/*": ["./*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "target",
    "coverage",
    "test-results",
    "playwright-report",
    "**/*.test.*",
    "**/*.spec.*"
  ],
  "include": [],
  "references": []
}
