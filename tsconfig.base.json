{
  "extends": "./packages/config/typescript/base.json",
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@epsx/api-client": ["packages/api-client/src/index.ts"],
      "@epsx/config/*": ["packages/config/*"],
      "@epsx/shared": ["packages/shared/src/index.ts"],
      "@epsx/types": ["packages/types/src/index.ts"],
      "@epsx/ui": ["packages/ui/src/index.ts"],
      "@epsx/utils": ["packages/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "**/dist/**"]
}
