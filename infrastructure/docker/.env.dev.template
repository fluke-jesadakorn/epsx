# ============================================================================
# EPSX Development Environment
# Copy to server ~/epsx/.env.dev and fill in real values
# ============================================================================

# --- Architecture ---
# Set to linux/amd64 or linux/arm64 depending on server
DOCKER_PLATFORM=linux/arm64

# --- Environment ---
ENV=development
NODE_ENV=development
RUST_ENV=development
RUST_LOG=info,epsx=debug
LOG_LEVEL=debug

# --- Service URLs (Cloudflare Tunnel) ---
BACKEND_URL=https://dev-api.epsx.io
FRONTEND_URL=https://dev.epsx.io
ADMIN_FRONTEND_URL=https://dev-admin.epsx.io

# --- Database (uses different port/name to coexist with prod) ---
DB_NAME=epsx_dev
DB_USER=epsx_user
DB_PASSWORD=<CHANGE_ME_DEV_PASSWORD>
DB_PORT=5433

# Database Pool
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=300

# --- PgBouncer ---
PGBOUNCER_ADMIN_PASSWORD=<CHANGE_ME_DEV_PASSWORD>

# --- Redis (uses different port to coexist with prod) ---
REDIS_PASSWORD=<CHANGE_ME_DEV_PASSWORD>
REDIS_PORT=6380

# --- Web3 Authentication ---
WEB3_APP_SECRET=<CHANGE_ME_DEV_32_CHAR_SECRET>
WALLET_SIGNATURE_SECRET=<CHANGE_ME_DEV_32_CHAR_SECRET>
WEB3_SESSION_SECRET=<CHANGE_ME_DEV_32_CHAR_SECRET>
WEB3_SESSION_DURATION_HOURS=24
WEB3_SIGNATURE_TIMEOUT_MINUTES=10
JWT_SECRET=<CHANGE_ME_DEV_32_CHAR_SECRET>

# --- Blockchain ---
BLOCKCHAIN_NETWORK=testnet
CHAIN_ID=97
COMPANY_WALLET_MAINNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
COMPANY_WALLET_TESTNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
BSC_MAINNET_RPC_URL=https://bsc-dataseed1.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BLOCKCHAIN_CONFIRMATION_TIMEOUT_SECONDS=120
BSC_REQUIRED_CONFIRMATIONS=12
BSC_TESTNET_REQUIRED_CONFIRMATIONS=6
MAX_PAYMENT_AGE_MINUTES=30

# --- WalletConnect ---
WALLETCONNECT_PROJECT_ID=04e0a500abfa1e095bf8f64b15fa2812
OAUTH_CLIENT_ID=epsx-frontend

# --- MinIO Object Storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<CHANGE_ME_DEV_MINIO_PASSWORD>
MINIO_PUBLIC_URL=http://localhost:9200

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=<YOUR_DEV_TUNNEL_TOKEN>
# Host LAN IP — used by dev cloudflared to reach bun dev via host.docker.internal
# Find with: ifconfig | grep "inet " | grep -v 127 | awk '{print $2}'
HOST_IP=192.168.0.33
