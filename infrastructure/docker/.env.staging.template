# ============================================================================
# EPSX Staging Environment
# Copy to server and fill in real values: cp .env.staging.template .env.staging
# ============================================================================

# --- Architecture ---
DOCKER_PLATFORM=linux/arm64

# --- Environment ---
ENV=staging
NODE_ENV=production
RUST_ENV=staging
RUST_LOG=info,epsx=debug
LOG_LEVEL=info

# --- Service URLs (Cloudflare Tunnel) ---
BACKEND_URL=https://staging-api.epsx.io
FRONTEND_URL=https://staging.epsx.io
ADMIN_FRONTEND_URL=https://staging-admin.epsx.io
PAY_URL=https://staging-pay.epsx.io               # wave49(slice-1)

# --- Database (different port/name to coexist with prod+dev) ---
DB_NAME=epsx_staging
DB_USER=epsx_user
DB_PASSWORD=<CHANGE_ME_STAGING_PASSWORD>
DB_PORT=5434

# Database Pool
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=300

# --- Redis (different port to coexist) ---
REDIS_PASSWORD=<CHANGE_ME_STAGING_PASSWORD>
REDIS_PORT=6381

# --- Web3 Authentication ---
WEB3_APP_SECRET=<CHANGE_ME_STAGING_32_CHAR_SECRET>
WALLET_SIGNATURE_SECRET=<CHANGE_ME_STAGING_32_CHAR_SECRET>
WEB3_SESSION_SECRET=<CHANGE_ME_STAGING_32_CHAR_SECRET>
WEB3_SESSION_DURATION_HOURS=24
WEB3_SIGNATURE_TIMEOUT_MINUTES=10
JWT_SECRET=<CHANGE_ME_STAGING_32_CHAR_SECRET>

# --- Blockchain (testnet for staging) ---
BLOCKCHAIN_NETWORK=testnet
CHAIN_ID=97
COMPANY_WALLET_MAINNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
COMPANY_WALLET_TESTNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
BSC_MAINNET_RPC_URL=https://bsc-dataseed1.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BLOCKCHAIN_CONFIRMATION_TIMEOUT_SECONDS=120
BSC_REQUIRED_CONFIRMATIONS=12
BSC_TESTNET_REQUIRED_CONFIRMATIONS=6
MAX_PAYMENT_AGE_MINUTES=30

# --- WalletConnect ---
WALLETCONNECT_PROJECT_ID=04e0a500abfa1e095bf8f64b15fa2812
OAUTH_CLIENT_ID=epsx-frontend

# --- MinIO Object Storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<CHANGE_ME_STAGING_MINIO_PASSWORD>
MINIO_PUBLIC_URL=https://staging-minio.epsx.io
