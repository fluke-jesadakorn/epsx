# ============================================================================
# EPSX GitLab CE - Environment Configuration
# Copy to .env.gitlab and fill in real values
# ============================================================================

# --- GitLab ---
GITLAB_HOSTNAME=gitlab.epsx.io
REGISTRY_HOSTNAME=registry.epsx.io

# Local ports (behind Cloudflare Tunnel, only exposed to 127.0.0.1)
GITLAB_HTTP_PORT=8929
GITLAB_REGISTRY_PORT=5050

# Initial root password (set on first boot, change after)
GITLAB_ROOT_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# --- Traefik ---
TRAEFIK_PORT=8930

# --- Runner ---
# Get this from GitLab Admin > CI/CD > Runners after first boot
GITLAB_RUNNER_TOKEN=<RUNNER_REGISTRATION_TOKEN>
