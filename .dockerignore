# Build context for apps/frontend/Dockerfile — exclude noise so COPY is fast.

# Build artifacts
target/
**/target/

# VCS
.git/
.gitignore
.gitattributes

# Old (pre-migration) apps that aren't built by this Dockerfile
apps-old/

# Local env / IDE / OS
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
.idea/
.vscode/
.DS_Store
*.swp
*.swo
*~

# CI / logs
**/*.log
**/coverage/
**/.coverage

# Test outputs
**/junit.xml
**/test-results/

# Bun / Node (Next.js used to live here; ignore leftovers)
node_modules/
.bun/
bun.lock
package-lock.json
yarn.lock
pnpm-lock.yaml
**/node_modules/
**/.next/
**/.turbo/
**/dist/
**/build/

# Rust-specific noise
**/Cargo.lock.bak
**/*.pdb
**/*.d
**/*.rlib
