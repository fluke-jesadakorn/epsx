# EPSX Production Environment Variables
# Copy this file and configure with your actual production values

# ============================================================================
# GOOGLE CLOUD CONFIGURATION
# ============================================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
ARTIFACT_REGISTRY_REPO=your-artifact-repo

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=your-32-character-jwt-secret-here
COOKIE_ENCRYPTION_KEY=your-32-character-encryption-key-here

# OIDC Configuration
OIDC_CLIENT_ID=your-frontend-client-id
OIDC_CLIENT_SECRET=your-frontend-client-secret
OIDC_ADMIN_CLIENT_ID=your-admin-client-id
OIDC_ADMIN_CLIENT_SECRET=your-admin-client-secret

# ============================================================================
# APPLICATION URLS (Cloudflare Mapped)
# ============================================================================
FRONTEND_URL=https://epsx.io
ADMIN_FRONTEND_URL=https://admin.epsx.io
BACKEND_URL=https://api.epsx.io

# Application URLs for JWT Authentication
APP_URL=https://epsx.io
ADMIN_URL=https://admin.epsx.io

# Public URLs for client-side
NEXT_PUBLIC_BACKEND_URL=https://api.epsx.io
NEXT_PUBLIC_APP_URL=https://epsx.io
NEXT_PUBLIC_ADMIN_URL=https://admin.epsx.io
SITE_URL=https://epsx.io

# ============================================================================
# DATABASE CONFIGURATION  
# ============================================================================
DATABASE_URL=postgresql://username:password@your-db-host/your-database?sslmode=require

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Web App Config (Public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ============================================================================
# RUNTIME ENVIRONMENT
# ============================================================================
NODE_ENV=production
RUST_LOG=info
RUST_BACKTRACE=0

# Performance & Resource Management
NODE_OPTIONS=--max-old-space-size=512
MALLOC_ARENA_MAX=2

# Feature Flags
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_BUILD_MODE=production

# ============================================================================
# OPTIONAL SERVICES
# ============================================================================

# Redis (if using)
# REDIS_URL=redis://your-redis-instance

# Email Service (if using)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Analytics (if using)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================================================
# NOTES
# ============================================================================
# 1. Replace all placeholder values with your actual production values
# 2. Keep this file secure and never commit to version control
# 3. Use Google Secret Manager for sensitive values in production
# 4. Update Cloudflare DNS to point domains to Cloud Run URLs
# 5. Verify SSL certificates are properly configured