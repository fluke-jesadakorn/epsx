# EPSX Backend Serverless Environment Configuration
# Platform-Agnostic Serverless Deployment with Stateless Architecture
# 
# Copy this file to serverless.env and configure for your serverless deployment
# Works with any containerized serverless platform
# 
# Key Features:
# - Stateless per-request service instantiation
# - Global database connection pooling for performance
# - Redis-only caching (no memory fallback)
# - Platform-agnostic serverless optimization

# =============================================================================
# CORE INFRASTRUCTURE - Required for serverless deployment
# =============================================================================

# Database Configuration - REQUIRED
DATABASE_URL="postgresql://user:password@host:5432/epsx_db"

# Redis Cache - REQUIRED for serverless (no memory fallback)
REDIS_URL="redis://host:6379"

# Application URLs - REQUIRED
FRONTEND_URL="https://epsx.io"
BACKEND_URL="https://api.epsx.io"
ADMIN_FRONTEND_URL="https://admin.epsx.io"

# =============================================================================
# AUTHENTICATION - Required for OIDC/Web3
# =============================================================================

# NextAuth Configuration
NEXTAUTH_SECRET="your-32-character-minimum-secret-key"

# OIDC Client Configuration
OIDC_CLIENT_ID="epsx-frontend"
OIDC_CLIENT_SECRET="your-oidc-client-secret"
OIDC_ADMIN_CLIENT_ID="epsx-admin"
OIDC_ADMIN_CLIENT_SECRET="your-oidc-admin-secret"

# Firebase Configuration - Required for authentication
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"

# =============================================================================
# SERVERLESS OPTIMIZATION - Generic platform settings
# =============================================================================

# Runtime Configuration
RUST_LOG="info"                    # Optimized for serverless logging
NODE_ENV="production"

# Serverless Configuration
PORT="8080"                        # Standard port for most platforms

# Serverless Performance Tuning
DATABASE_MAX_CONNECTIONS="10"      # Optimized for serverless scaling
DATABASE_MIN_CONNECTIONS="1"       # Minimal for serverless cold starts
DATABASE_ACQUIRE_TIMEOUT="5"       # Fast timeout for serverless
REDIS_POOL_SIZE="5"                # Smaller pool for serverless
CACHE_DEFAULT_TTL="1800"           # 30 minutes - good for serverless

# =============================================================================
# PLATFORM AGNOSTIC SETTINGS
# =============================================================================

# Health Check Configuration
HEALTH_CHECK_TIMEOUT="5"
STARTUP_PROBE_TIMEOUT="10"

# Generic Serverless Settings (customize for your platform)
SERVERLESS_CONCURRENCY="100"      # Requests per instance
SERVERLESS_MAX_INSTANCES="10"     # Auto-scale up to 10 instances
SERVERLESS_MIN_INSTANCES="0"      # Scale to zero when idle
SERVERLESS_TIMEOUT="300"          # 5 minute request timeout

# =============================================================================
# OPTIONAL PAYMENT SERVICES
# =============================================================================

# MusePay Configuration (Optional)
MUSEPAY_PARTNER_ID="your-partner-id"
MUSEPAY_PRIVATE_KEY="your-private-key"

# =============================================================================
# SECURITY & MONITORING
# =============================================================================

# CORS Configuration for serverless
CORS_ALLOW_ORIGIN="*"              # Platform handles CORS
CORS_ALLOW_CREDENTIALS="false"     # Required when using wildcard origin

# Rate Limiting (handled by platform)
RATE_LIMIT_ENABLED="false"         # Platform provides rate limiting

# Monitoring
ENABLE_TELEMETRY="true"
TELEMETRY_ENDPOINT="https://api.epsx.io/telemetry"

# =============================================================================
# CLIENT-SIDE ENVIRONMENT VARIABLES
# =============================================================================

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL="https://api.epsx.io"
NEXT_PUBLIC_APP_URL="https://epsx.io"
NEXT_PUBLIC_ADMIN_URL="https://admin.epsx.io"
NEXT_PUBLIC_OAUTH_CLIENT_ID="epsx-frontend"

# Firebase Client Configuration
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-firebase-project-id"

# Web3 Configuration
NEXT_PUBLIC_BLOCKCHAIN_NETWORK="mainnet"  # or "testnet"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="epsx-web3-frontend"

# =============================================================================
# DEPLOYMENT METADATA
# =============================================================================

DEPLOYMENT_TARGET="serverless"
DEPLOYMENT_PLATFORM="generic-serverless"  # Customize for your platform
DEPLOYMENT_REGION="your-region"           # Customize for your platform
DEPLOYMENT_TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# =============================================================================
# SERVERLESS ARCHITECTURE NOTES
# =============================================================================

# Key Differences from Standard Deployment:
# 
# 1. STATELESS SERVICES:
#    - Services created per request (no shared state)
#    - No Arc<T> containers or shared memory
#    - Database connections from global pool
#
# 2. CACHE STRATEGY:
#    - Redis-only caching (REDIS_URL required)
#    - No memory cache fallback
#    - Optimized for multi-instance scaling
#
# 3. CONNECTION MANAGEMENT:
#    - Global database pool cached across requests
#    - Smaller connection pools for faster startup
#    - Optimized timeouts for serverless environments
#
# 4. PERFORMANCE OPTIMIZATION:
#    - Cold start optimization with service warm-up
#    - Optimized logging for serverless platforms
#    - Minimal Docker image size
#    - Pre-compiled dependencies
#
# 5. SCALING BEHAVIOR:
#    - Auto-scale from 0 to N instances (platform dependent)
#    - Per-request service instantiation
#    - No persistent state between requests
#    - Optimized for traffic spikes

# =============================================================================
# DEPLOYMENT COMMANDS
# =============================================================================

# To build serverless version:
# ./scripts/deploy/deploy-serverless.sh

# To test locally with serverless config:
# cargo run --bin serverless_handler --features serverless

# To run Docker container locally:
# docker run -p 8080:8080 --env-file serverless.env epsx-backend-serverless:latest

# Platform-specific deployment examples:
# 
# AWS Lambda:
# - Package as container image and deploy to Lambda
# - Configure environment variables in Lambda console
# 
# Azure Container Instances:
# - Deploy using az container create
# - Set environment variables with --environment-variables
# 
# Google Cloud Run:
# - gcloud run deploy --image your-image --set-env-vars="..."
# 
# Kubernetes:
# - Create Deployment and Service manifests
# - Apply with kubectl apply -f manifests/