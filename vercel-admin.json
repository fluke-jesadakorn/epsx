{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && bun run build:admin",
  "framework": "nextjs",
  "installCommand": "cd ../.. && bun install",
  "outputDirectory": "apps/admin-frontend/.next",
  "rootDirectory": "apps/admin-frontend",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/admin-frontend/ packages/",
  "env": {
    "NEXT_PUBLIC_API_URL": "@next_public_admin_api_url",
    "NEXT_PUBLIC_APP_URL": "@next_public_admin_app_url",
    "NEXT_PUBLIC_ADMIN_URL": "@next_public_admin_url"
  },
  "functions": {
    "apps/admin-frontend/app/api/**/*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
