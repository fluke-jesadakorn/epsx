{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.*"],
  "globalEnv": ["NODE_ENV", "PORT", "DATABASE_URL", "API_KEY", "NEXT_PUBLIC_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "type-check"],
      "outputs": ["dist/**", ".next/**", "build/**", "packages/*/dist/**"],
      "inputs": ["src/**/*", "app/**/*", "tsconfig.json", "package.json", "turbo.json"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**", "test-results/**"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx",
        "jest.config.*"
      ],
      "cache": true
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**/*", "app/**/*", "*.config.*"],
      "cache": true
    },
    "type-check": {
      "outputs": [],
      "inputs": ["src/**/*", "app/**/*", "tsconfig.json"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "inputs": ["src/**/*", "app/**/*", "tsconfig.json"]
    },
    "clean": {
      "cache": false,
      "inputs": ["package.json"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "//#clean": {
      "cache": false,
      "inputs": ["package.json"]
    }
  }
}
