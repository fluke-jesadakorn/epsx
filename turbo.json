{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_*",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "target/**", "build/**"]
    },
    "build:admin": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "build:fe": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"],
      "env": ["NEXT_PUBLIC_*", "FIREBASE_*"]
    },
    "# build:be": {
      "comment": "Rust backend temporarily disabled from monorepo",
      "dependsOn": ["^build"],
      "outputs": ["target/**"]
    },
    "build:pkg": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:auth": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:admin": {
      "cache": false,
      "persistent": true
    },
    "dev:fe": {
      "cache": false,
      "persistent": true,
      "env": ["NEXT_PUBLIC_*", "FIREBASE_*"]
    },
    "# dev:be": {
      "comment": "Rust backend temporarily disabled from monorepo",
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build", "build"],
      "cache": false
    },
    "start:fe": {
      "dependsOn": ["build:fe"],
      "cache": false
    },
    "# start:be": {
      "comment": "Rust backend temporarily disabled from monorepo",
      "dependsOn": ["build:be"],
      "cache": false
    },
    "lint": {
      "outputs": ["node_modules/.cache/.eslintcache"]
    },
    "lint:fix": {
      "outputs": ["node_modules/.cache/.eslintcache"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
