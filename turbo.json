{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "target/**",
        "build/**"
      ]
    },
    "build:fe": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"]
    },
    "build:be": {
      "dependsOn": ["^build"],
      "outputs": ["target/**"]
    },
    "build:pkg": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:fe": {
      "cache": false,
      "persistent": true
    },
    "dev:be": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
