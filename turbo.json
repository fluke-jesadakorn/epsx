{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env*",
    "turbo.json",
    "pnpm-workspace.yaml"
  ],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "FIREBASE_*"
  ],
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", "target/**", "build/**"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "package.json",
        "tsconfig.json",
        "next.config.*",
        "tailwind.config.*",
        "postcss.config.*"
      ]
    },
    "build:apps": {
      "outputs": [".next/**"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "package.json",
        "tsconfig.json",
        "next.config.*"
      ]
    },
    "build:frontend": {
      "outputs": [".next/**"],
      "env": ["FIREBASE_*"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "package.json",
        "tsconfig.json",
        "next.config.*"
      ]
    },
    "build:admin": {
      "outputs": [".next/**"],
      "env": [],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "package.json",
        "tsconfig.json",
        "next.config.*"
      ]
    },
    "build:backend": {
      "dependsOn": [],
      "outputs": ["target/**"],
      "inputs": ["src/**", "Cargo.toml", "Cargo.lock"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:frontend": {
      "cache": false,
      "persistent": true,
      "env": ["NEXT_PUBLIC_*", "FIREBASE_*"]
    },
    "dev:admin": {
      "cache": false,
      "persistent": true,
      "env": []
    },
    "dev:backend": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "start:frontend": {
      "cache": false,
      "env": ["NEXT_PUBLIC_*", "FIREBASE_*"]
    },
    "start:admin": {
      "cache": false,
      "env": []
    },
    "start:backend": {
      "cache": false
    },
    "lint": {
      "outputs": ["node_modules/.cache/.eslintcache"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "*.js",
        "*.ts",
        "*.tsx",
        ".eslintrc.*",
        "eslint.config.*"
      ]
    },
    "lint:fix": {
      "outputs": ["node_modules/.cache/.eslintcache"],
      "cache": false
    },
    "type-check": {
      "outputs": ["**/.cache/.tsbuildinfo", "node_modules/.cache/tsbuildinfo.json"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "package.json",
        "tsconfig.json"
      ]
    },
    "test": {
      "outputs": ["coverage/**", "test-results/**", "target/debug/**"]
    },
    "test:domain": {
      "outputs": ["coverage/domain/**", "target/debug/**"],
      "inputs": [
        "src/dom/**",
        "utils/**",
        "lib/utils/**",
        "__tests__/domain/**",
        "tests/domain/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "jest.config.*",
        "Cargo.toml"
      ]
    },
    "test:application": {
      "outputs": ["coverage/application/**", "target/debug/**"],
      "inputs": [
        "src/app/**",
        "hooks/**",
        "lib/actions/**",
        "lib/state/**",
        "__tests__/application/**",
        "tests/application/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "jest.config.*",
        "Cargo.toml"
      ]
    },
    "test:infrastructure": {
      "outputs": ["coverage/infrastructure/**", "target/debug/**"],
      "inputs": [
        "src/infra/**",
        "lib/api/**",
        "lib/services/**",
        "__tests__/infrastructure/**",
        "tests/infrastructure/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "jest.config.*",
        "Cargo.toml"
      ]
    },
    "test:presentation": {
      "outputs": ["coverage/presentation/**", "target/debug/**"],
      "inputs": [
        "src/web/**",
        "app/**",
        "components/**",
        "__tests__/presentation/**",
        "tests/presentation/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "jest.config.*",
        "Cargo.toml"
      ]
    },
    "test:unit": {
      "outputs": ["coverage/**", "target/debug/**"]
    },
    "test:integration": {
      "outputs": ["coverage/**", "target/debug/**"]
    },
    "test:backend": {
      "outputs": ["target/debug/**"]
    },
    "test:frontend": {
      "outputs": ["coverage/**"]
    },
    "test:admin": {
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "outputs": ["test-results/**", "playwright-report/**"],
      "inputs": ["e2e/**", "playwright.config.*"]
    },
    "test:e2e:frontend": {
      "outputs": ["test-results/**", "playwright-report/**"],
      "inputs": ["e2e/**", "playwright.config.*"]
    },
    "test:e2e:admin": {
      "outputs": ["test-results/**", "playwright-report/**"],
      "inputs": ["e2e/**", "playwright.config.*"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:ci": {
      "outputs": ["coverage/**", "test-results/**", "target/debug/**"]
    },
    "test:parallel": {
      "outputs": ["coverage/**", "target/debug/**"]
    },
    "format": {
      "outputs": [],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "**/*.{js,ts,tsx,json,md,yml,yaml}",
        ".prettierrc*",
        "prettier.config.*"
      ]
    },
    "format:check": {
      "outputs": [],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "utils/**",
        "types/**",
        "**/*.{js,ts,tsx,json,md,yml,yaml}",
        ".prettierrc*",
        "prettier.config.*"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
