# EPSX Development Environment Configuration - Web3 Wallet-First System
# Copy this file to .env and update with your development values

ENV=development
NODE_ENV=development
RUST_ENV=development

# Development URLs
BACKEND_URL=https://dev-api.epsx.io
FRONTEND_URL=https://dev.epsx.io
ADMIN_FRONTEND_URL=https://dev-admin.epsx.io

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=https://dev-api.epsx.io
NEXT_PUBLIC_APP_URL=https://dev.epsx.io
NEXT_PUBLIC_ADMIN_URL=https://dev-admin.epsx.io

# Core Infrastructure (Required - 1 variable)
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/epsx_dev

# Web3 Authentication Configuration (Required)
# Modern Web3-first authentication using SIWE (Sign-In with Ethereum)
# No traditional email/password or OIDC authentication - wallet signatures only
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=epsx-web3-frontend

# Web3 Session Management (Required)
# Session tokens for authenticated wallet users
WEB3_SESSION_SECRET=web3-session-secret-32-chars-minimum-replace-this
WEB3_SESSION_DURATION_HOURS=24
WEB3_SIGNATURE_TIMEOUT_MINUTES=10

# Crypto Payment Configuration (Required for blockchain verification)
# Company wallet addresses for receiving payments
COMPANY_WALLET_MAINNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
COMPANY_WALLET_TESTNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7

# Client-accessible payment addresses (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_PAYMENT_MAINNET_ADDRESS=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
NEXT_PUBLIC_PAYMENT_TESTNET_ADDRESS=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7

# BSC RPC Endpoints (Optional - uses defaults if not provided)
# BSC_MAINNET_RPC_1=https://bsc-dataseed1.binance.org/
# BSC_MAINNET_RPC_2=https://bsc-dataseed2.binance.org/
# BSC_MAINNET_RPC_3=https://bsc.rpc.blxrbdn.com/
# BSC_TESTNET_RPC_1=https://data-seed-prebsc-1-s1.binance.org:8545/
# BSC_TESTNET_RPC_2=https://data-seed-prebsc-2-s1.binance.org:8545/

# Blockchain Verification Settings (Optional - uses defaults if not provided)
# BLOCKCHAIN_CONFIRMATION_TIMEOUT_SECONDS=120
# BSC_REQUIRED_CONFIRMATIONS=12
# BSC_TESTNET_REQUIRED_CONFIRMATIONS=6
# MAX_PAYMENT_AGE_MINUTES=30

# Infrastructure (Optional)
REDIS_URL=redis://localhost:6379
LOG_LEVEL=debug

# Testing (Optional - for E2E tests)
TEST_ADMIN_EMAIL=your-test-admin@example.com
TEST_ADMIN_PASSWORD=your-test-password
