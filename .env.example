# EPSX Development Environment Configuration
# Copy to .env and update with your development values

# === Environment ===
ENV=development
NODE_ENV=development
RUST_ENV=development
LOG_LEVEL=debug

# === Service URLs ===
BACKEND_URL=https://dev-api.epsx.io              # format: https://...
FRONTEND_URL=https://dev.epsx.io                  # format: https://...
ADMIN_FRONTEND_URL=https://dev-admin.epsx.io      # format: https://...

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=https://dev-api.epsx.io
NEXT_PUBLIC_APP_URL=https://dev.epsx.io
NEXT_PUBLIC_ADMIN_URL=https://dev-admin.epsx.io

# === PostgreSQL ===
DB_NAME=epsx_dev
DB_USER=epsx_user
DB_PASSWORD=password                              # required
DB_PORT=5432
DATABASE_URL=postgresql://epsx_user:password@localhost:5432/epsx_dev?sslmode=disable
ANALYTICS_DATABASE_URL=postgresql://epsx_user:password@localhost:5432/epsx_analytics_dev?sslmode=disable
NOTIFICATIONS_DATABASE_URL=postgresql://epsx_user:password@localhost:5432/epsx_notifications_dev?sslmode=disable
PAYMENTS_DATABASE_URL=postgresql://epsx_user:password@localhost:5432/epsx_payments_dev?sslmode=disable

# === Redis ===
REDIS_PASSWORD=dev_redis_password                 # required
REDIS_URL=redis://localhost:6379

# === MinIO (S3 Object Storage) ===
MINIO_ROOT_USER=minioadmin                        # required
MINIO_ROOT_PASSWORD=minioadmin                    # required
MINIO_PUBLIC_URL=https://cdn.dev.epsx.io          # format: https://...

# === Web3 Authentication ===
WEB3_APP_SECRET=dev_secret_32_chars_minimum       # required
WALLET_SIGNATURE_SECRET=dev_wallet_sig_secret     # required
WEB3_SESSION_SECRET=dev_session_secret            # required
JWT_SECRET=dev_jwt_secret                         # required
WEB3_SESSION_DURATION_HOURS=24
WEB3_SIGNATURE_TIMEOUT_MINUTES=5

# === Blockchain ===
BLOCKCHAIN_NETWORK=testnet                        # format: mainnet|testnet
CHAIN_ID=97                                       # format: number (97=testnet, 56=mainnet)
COMPANY_WALLET_MAINNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7  # format: 0x + 40 hex
COMPANY_WALLET_TESTNET=0x7877e415a13532d9E43Df7Fd2CC256f93a39ced7
BSC_MAINNET_RPC_URL=https://bsc-dataseed1.binance.org              # format: https://...
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BLOCKCHAIN_CONFIRMATION_TIMEOUT_SECONDS=120
BSC_REQUIRED_CONFIRMATIONS=12
BSC_TESTNET_REQUIRED_CONFIRMATIONS=6
MAX_PAYMENT_AGE_MINUTES=30

# === WalletConnect / OAuth ===
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id  # required
OAUTH_CLIENT_ID=epsx-frontend                           # required
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=testnet
NEXT_PUBLIC_CHAIN_ID=97

# === Payment Contracts ===
NEXT_PUBLIC_PAYMENT_ESCROW_MAINNET=0x0000000000000000000000000000000000000000  # format: 0x + 40 hex
NEXT_PUBLIC_PAYMENT_RECEIVER_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYMENT_ESCROW_TESTNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYMENT_RECEIVER_TESTNET=0x0000000000000000000000000000000000000000

# === Cloudflare Tunnel (prod only) ===
# CLOUDFLARE_TUNNEL_TOKEN=                        # format: JWT (3 base64url segments)
