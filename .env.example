# EPSX Development Environment Configuration
# Copy this file to .env and update with your development values

ENV=development
NODE_ENV=development
RUST_ENV=development

# Development URLs
BACKEND_URL=https://dev-api.epsx.io
FRONTEND_URL=https://dev.epsx.io
ADMIN_FRONTEND_URL=https://dev-admin.epsx.io

# Client-accessible URLs (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=https://dev-api.epsx.io
NEXT_PUBLIC_APP_URL=https://dev.epsx.io
NEXT_PUBLIC_ADMIN_URL=https://dev-admin.epsx.io

# Core Infrastructure (Required - 4 variables)
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/epsx_dev
NEXTAUTH_SECRET=dev-secret-32-chars-minimum-replace-this

# OIDC Configuration (Required - 4 variables)  
OIDC_CLIENT_ID=epsx-frontend-dev
OIDC_CLIENT_SECRET=dev-oidc-client-secret-replace-this
OIDC_ADMIN_CLIENT_ID=epsx-admin-dev
OIDC_ADMIN_CLIENT_SECRET=dev-oidc-admin-secret-replace-this

# Firebase Configuration (Required - 3 variables)
FIREBASE_PROJECT_ID=your-dev-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_DEV_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-dev-service-account@project.iam.gserviceaccount.com

# Client-accessible Firebase (Optional - 7 variables)
NEXT_PUBLIC_FIREBASE_API_KEY=your-dev-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-dev-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-analytics-measurement-id

# Optional Services (2 variables)
MUSEPAY_PARTNER_ID=your-dev-musepay-partner-id
MUSEPAY_PRIVATE_KEY=your-dev-musepay-private-key

# Infrastructure (Optional)
REDIS_URL=redis://localhost:6379
LOG_LEVEL=debug

# Testing (Optional - for E2E tests)
TEST_ADMIN_EMAIL=your-test-admin@example.com
TEST_ADMIN_PASSWORD=your-test-password
